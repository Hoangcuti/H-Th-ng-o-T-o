@model COTHUYPRO.Models.DashboardViewModel
@{
    ViewData["Title"] = "Training Portal";
}

<section class="hero-alt container-xxl animate-fade-in">
    <div class="hero-card">
        <div class="hero-copy">
            <span class="pill">Nội bộ nhanh · Trải nghiệm mượt</span>
            <h1 class="text-gradient">Học tập, quản trị và báo cáo trong một màn hình.</h1>
            <p class="lead delay-100 animate-fade-in" style="animation-fill-mode: both;">Khởi tạo lớp, gán giảng viên, theo dõi tiến độ và cấp chứng chỉ cho học viên chỉ với vài cú nhấp.</p>
            <div class="hero-actions delay-200 animate-fade-in" style="animation-fill-mode: both;">
                <a class="btn solid lg" href="#courses">Bắt đầu học</a>
                <a class="btn ghost lg" href="#classes">Xem lịch</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    if (User.IsInRole("Admin")) { <a class="btn accent lg" asp-controller="Admin" asp-action="Index">Bảng quản trị</a>; }
                    else if (User.IsInRole("Instructor")) { <a class="btn accent lg" asp-controller="Instructor" asp-action="Index">Vào lớp giảng</a>; }
                    else if (User.IsInRole("Student")) { <a class="btn accent lg" asp-controller="Student" asp-action="Index">Vào học ngay</a>; }
                }
            </div>
            <div class="feature-grid">
                <div class="feature-chip">✔ Theo dõi tiến độ</div>
                <div class="feature-chip">✔ Chấm Quiz tự động</div>
                <div class="feature-chip">✔ Cấp chứng chỉ</div>
                <div class="feature-chip">✔ Báo cáo theo khóa</div>
            </div>
        </div>
        <div class="hero-stats delay-300 animate-fade-in" style="animation-fill-mode: both;">
            <div class="stat">
                <p class="label">Khóa học</p>
                <h2>@Model.TotalCourses</h2>
            </div>
            <div class="stat">
                <p class="label">Lớp mở</p>
                <h2>@Model.ActiveClasses</h2>
            </div>
            <div class="stat">
                <p class="label">Học viên</p>
                <h2>@Model.TotalStudents</h2>
            </div>
            <div class="stat timeline-tiny">
                <p class="label">Lịch sắp tới</p>
                @foreach (var cls in Model.UpcomingClasses.Take(2))
                {
                    <div class="timeline-row compact">
                        <div>
                            <div class="t-title">@cls.CourseName</div>
                            <div class="t-sub">@cls.Instructor · @cls.Room</div>
                        </div>
                        <span class="t-date">@cls.Schedule.ToLocalTime().ToString("dd/MM")</span>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<section id="courses" class="panel container-xxl animate-fade-in delay-200" style="animation-fill-mode: both;">
    <div class="panel-header">
        <div>
            <p class="label">Khóa học</p>
            <h2 class="section-title">Lộ trình theo ngành</h2>
            <p class="section-sub">Sắp xếp theo danh mục và cấp độ, hiển thị tiến độ học viên.</p>
        </div>
        <span class="chip">Admin · Giảng viên · Học viên</span>
    </div>
    <div class="course-grid">
        @foreach (var course in Model.Courses)
        {
            <div class="course-card">
                <div class="course-meta">
                    <span class="badge">@course.Category</span>
                    <span class="level">@course.Level</span>
                </div>
                <h3>@course.Title</h3>
                <p class="muted">Giảng viên: @string.Join(", ", course.Instructors)</p>
                <div class="progress">
                    <div class="progress-bar" role="progressbar" style="width:@course.Progress%" aria-valuenow="@course.Progress" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                <div class="progress-label">@course.Progress% tiến độ mẫu (học viên)</div>
                <div class="card-actions">
                    <a class="btn ghost btn-sm" href="#classes">Xem lịch</a>
                    @if (User.IsInRole("Instructor") || User.IsInRole("Admin"))
                    {
                        <a class="btn solid btn-sm" asp-controller="Instructor" asp-action="Index">Quản lý nội dung</a>
                    }
                </div>
            </div>
        }
    </div>
</section>

<section id="classes" class="panel container-xxl animate-fade-in delay-300" style="animation-fill-mode: both;">
    <div class="panel-header">
        <div>
            <p class="label">Lịch học</p>
            <h2 class="section-title">Lớp sắp diễn ra</h2>
            <p class="section-sub">Thời gian, phòng học và giảng viên phụ trách.</p>
        </div>
        <span class="chip">@Model.UpcomingClasses.Count lớp</span>
    </div>
    <div class="timeline">
        @foreach (var cls in Model.UpcomingClasses)
        {
            <div class="timeline-row">
                <div>
                    <div class="t-title">@cls.CourseName</div>
                    <div class="t-sub">@cls.Instructor · @cls.Room</div>
                </div>
                <span class="t-date">@cls.Schedule.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</span>
            </div>
        }
    </div>
</section>
