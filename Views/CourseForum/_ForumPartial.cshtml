@model List<COTHUYPRO.Models.CourseForumMessage>
@{
    int currentUserId = ViewBag.CurrentUserId ?? 0;
    int courseId = ViewBag.CourseId ?? 0;
}

<style>
    /* --- SILICON LIGHT FORUM UI --- */
    #forumScrollArea {
        max-height: 500px; overflow-y: auto; padding: 20px;
        scroll-behavior: smooth; background: rgba(248, 250, 252, 0.5);
        border-radius: 20px; margin-bottom: 20px;
    }
    #forumScrollArea::-webkit-scrollbar { width: 6px; }
    #forumScrollArea::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }

    .msg-item { display: flex; gap: 15px; margin-bottom: 24px; animation: slideUp 0.3s ease; }
    .msg-avatar {
        width: 45px; height: 45px; border-radius: 15px; background: #0ea5e9;
        color: #fff; display: flex; align-items: center; justify-content: center;
        font-weight: 800; font-size: 1.2rem; flex-shrink: 0;
        box-shadow: 0 5px 15px rgba(14, 165, 233, 0.2);
    }
    .msg-content { max-width: 80%; }
    .msg-bubble {
        background: #fff; padding: 16px 20px; border-radius: 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.03); border: 1px solid #eef2f6;
        position: relative; line-height: 1.6; color: #334155;
    }
    .msg-item.mine { flex-direction: row-reverse; }
    .msg-item.mine .msg-bubble { background: #f0f9ff; border-color: #bae6fd; }
    .msg-item.mine .msg-avatar { background: #6366f1; }

    .msg-meta { font-size: 0.75rem; color: #94a3b8; margin-bottom: 6px; font-weight: 600; display: flex; gap: 8px; align-items: center; }
    .msg-item.mine .msg-meta { justify-content: flex-end; }
    
    .role-badge { padding: 2px 8px; border-radius: 6px; font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 800; }
    .role-instructor { background: #fef3c7; color: #d97706; border: 1px solid #fde68a; }

    .forum-input-area {
        background: #fff; border: 2px solid #eef2f6; border-radius: 25px;
        padding: 8px 8px 8px 24px; display: flex; align-items: center; gap: 10px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05); transition: all 0.3s;
    }
    .forum-input-area:focus-within { border-color: #0ea5e9; box-shadow: 0 15px 40px rgba(14, 165, 233, 0.1); }
    .forum-input-area input { border: none; outline: none; flex-grow: 1; font-size: 1rem; color: #1e293b; }
    .forum-input-area button {
        background: linear-gradient(135deg, #0ea5e9, #6366f1); color: #fff;
        border: none; width: 45px; height: 45px; border-radius: 18px;
        transition: transform 0.2s;
    }
    .forum-input-area button:hover { transform: scale(1.1) rotate(5deg); }

    @("@")keyframes slideUp { 0% { transform: translateY(20px); opacity: 0; } 100% { transform: translateY(0); opacity: 1; } }
</style>

<div class="p-4">
    <div id="forumScrollArea">
        @if (!Model.Any()) {
            <div class="text-center py-5 opacity-50">
                <i class="fa-solid fa-comments display-4 mb-3"></i>
                <p class="fw-bold">CHƯA CÓ THẢO LUẬN NÀO... HÃY BẮT ĐẦU NGAY!</p>
            </div>
        }
        @foreach (var msg in Model) {
            bool isMine = msg.UserId == currentUserId;
            // GIẢ ĐỊNH: Nếu User có role Instructor hoặc Admin thì hiện badge
            bool isInstructor = msg.User?.FullName?.Contains("Admin") == true || msg.UserId == 1; // Logic này có thể mở rộng sau

            <div class="msg-item @(isMine ? "mine" : "")">
                <div class="msg-avatar">
                    @msg.User?.FullName?.Substring(0, 1).ToUpper()
                </div>
                <div class="msg-content">
                    <div class="msg-meta">
                        <span>@msg.User?.FullName</span>
                        @if (isInstructor) { <span class="role-badge role-instructor">GIẢNG VIÊN</span> }
                        <span>• @msg.CreatedAt.ToString("HH:mm")</span>
                    </div>
                    <div class="msg-bubble shadow-sm">
                        @msg.Content
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- INPUT -->
    <div class="forum-input-area">
        <input type="text" id="forumInput" placeholder="Nhập câu hỏi hoặc thảo luận với lớp học..." onkeypress="if(event.key === 'Enter') typeof postForumMessage === 'function' && postForumMessage()">
        <button onclick="typeof postForumMessage === 'function' && postForumMessage()">
            <i class="fa-solid fa-paper-plane"></i>
        </button>
    </div>
</div>
