@model COTHUYPRO.Models.Lesson
@{
    ViewData["Title"] = Model.Title;
    var allLessons = ViewBag.AllLessons as List<COTHUYPRO.Models.Lesson>;
}

<div class="container-xxl mt-4">
    <div class="row">
        <!-- Vùng học tập bên trái -->
        <div class="col-lg-8 animate-fade-in">
            <div class="d-flex align-items-center mb-3">
                <a asp-action="CourseDetail" asp-route-id="@Model.CourseId" class="btn btn-sm ghost me-3" style="font-size: 0.8rem;">
                    &larr; Quay lại khóa học
                </a>
                <h3 class="m-0">@Model.Title</h3>
            </div>

            <!-- Trình phát Video Giả lập -->
            <div class="video-container" style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; max-width: 100%; background: #000; border-radius: 16px; box-shadow: var(--shadow-xl);">
               <div style="position: absolute; top:0; left:0; width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); border: 1px solid rgba(255,255,255,0.05);">
                   <div style="font-size: 3rem; color: var(--primary); margin-bottom: 10px;">▶</div>
                   <h5 class="text-white">Video Bài Giảng: @Model.Title</h5>
                   <p class="muted">Minh họa giao diện phát video (Chờ link CDN)</p>
               </div>
            </div>

            <div class="panel-card mt-4">
                <h4>Nội dung chuyên sâu</h4>
                <div class="mt-3" style="line-height: 1.8; color: var(--muted);">
                    @if (ViewBag.ContentHTML == null)
                    {
                        <p>Nội dung chi tiết của bài học đang được biên soạn.</p>
                    }
                    else
                    {
                        @Html.Raw(ViewBag.ContentHTML)
                    }
                </div>
                
                <div class="mt-4 pt-4 text-end" style="border-top: 1px solid rgba(255,255,255,0.1);">
                    <button class="btn solid text-white" onclick="markCompleted()">Hoàn thành bài học</button>
                    <!-- Link tới bài Quiz nếu có (hiện tại tính năng Quiz cho Lesson đang phát triển) -->
                </div>
            </div>
        </div>

        <!-- Sidebar Danh sách bài bên phải -->
        <div class="col-lg-4 animate-fade-in delay-200">
            <div class="panel-card" style="position: sticky; top: 20px;">
                <div class="panel-head mb-3">
                    <h5 class="m-0">Danh sách bài học</h5>
                </div>
                <div class="lesson-list">
                    @for (int i=0; i < allLessons.Count; i++)
                    {
                        var l = allLessons[i];
                        var isActive = l.Id == Model.Id ? "border-color: var(--primary); background: rgba(6,182,212,0.1);" : "border-color: rgba(255,255,255,0.05); background: rgba(255,255,255,0.02);";
                        
                        <a asp-action="Lesson" asp-route-id="@l.Id" class="d-block p-3 mb-2" style="border: 1px solid; border-radius: 12px; @isActive transition: all 0.3s; text-decoration: none;">
                            <h6 class="mb-1 text-white" style="font-size: 0.95rem;">@(i+1). @l.Title</h6>
                            <small class="muted" style="font-size: 0.75rem;">Video & Tài liệu</small>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function markCompleted() {
            // Giả lập lưu API
            const toast = document.createElement('div');
            toast.className = 'custom-toast toast-success';
            toast.innerHTML = `
                <div class="toast-icon">✅</div>
                <div class="toast-content">
                    <div class="toast-title">Thành công!</div>
                    <div class="toast-message">Đã lưu tiến độ học tập. Chuyển sang bài tiếp theo.</div>
                </div>
                <button class="toast-close border-0 bg-transparent">&times;</button>
            `;
            document.querySelector('.toast-container').appendChild(toast);
            setTimeout(() => toast.classList.add('show'), 100);
            
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 400);
            }, 3000);
        }
    </script>
}
