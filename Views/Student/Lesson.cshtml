@{
    var isAdmin = User.IsInRole("Admin");
    Layout = isAdmin ? "~/Views/Shared/_AdminLayout.cshtml" : "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = Model.Title;
    var allLessons = ViewBag.AllLessons as List<COTHUYPRO.Models.Lesson>;
    var videoUrl = ViewBag.VideoUrl as string;
    var exams = ViewBag.Exams as List<COTHUYPRO.Models.Exam> ?? new List<COTHUYPRO.Models.Exam>();
    var prevId = ViewBag.PrevId as int?;
    var nextId = ViewBag.NextId as int?;

    string GetYoutubeEmbed(string? url) {
        if (string.IsNullOrEmpty(url)) return "";
        if (url.Contains("watch?v=")) return url.Replace("watch?v=", "embed/");
        if (url.Contains("youtu.be/")) return url.Replace("youtu.be/", "youtube.com/embed/");
        return url;
    }
    var embedUrl = GetYoutubeEmbed(videoUrl);
}

<style>
    /* --- SILICON LIGHT SCOPED --- */
    .sl-lesson-container { background: #fcfdfe; min-height: 100vh; padding-top: 40px; }
    
    .sl-video-canvas {
        background: #fff;
        border-radius: 28px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        border: 1px solid #eef2f6;
        transition: transform 0.3s ease;
    }
    .sl-video-canvas:hover { transform: translateY(-5px); box-shadow: 0 30px 60px rgba(0,0,0,0.12); }

    .sl-text-gradient {
        background: linear-gradient(135deg, #0ea5e9, #6366f1);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 800;
    }

    .sl-btn-vibrant {
        background: linear-gradient(135deg, #0ea5e9, #3b82f6);
        color: #fff !important;
        font-weight: 700;
        padding: 14px 32px;
        border-radius: 16px;
        border: none;
        box-shadow: 0 10px 20px rgba(14, 165, 233, 0.2);
        display: inline-flex; align-items: center; gap: 10px;
        text-decoration: none;
        transition: all 0.3s;
    }
    .sl-btn-vibrant:hover { transform: scale(1.05) translateY(-2px); box-shadow: 0 15px 30px rgba(14, 165, 233, 0.3); }

    .sl-glass-card {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border: 1px solid #eef2f6;
        border-radius: 24px;
        padding: 32px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.04);
    }

    .sl-lesson-item {
        display: flex; align-items: center; gap: 12px; padding: 14px;
        border-radius: 16px; transition: all 0.2s; text-decoration: none;
        color: #64748b; font-weight: 600; margin-bottom: 8px;
        border: 1px solid transparent;
    }
    .sl-lesson-item:hover { background: #f1f5f9; color: #0ea5e9; transform: translateX(5px); }
    .sl-lesson-item.active { background: #eff6ff; color: #2563eb; border-color: #dbeafe; }

    .sl-badge {
        background: #f0f9ff; color: #0ea5e9; padding: 4px 12px;
        border-radius: 8px; font-size: 0.75rem; font-weight: 800;
        text-transform: uppercase; letter-spacing: 0.05em;
    }
    
    @@keyframes shimmer { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }
    .shimmer-bg {
        background: linear-gradient(90deg, #f1f5f9, #ffffff, #f1f5f9);
        background-size: 200% 100%;
        animation: shimmer 2s infinite linear;
    }

    /* Content Body Enhancements */
    .sl-content-body {
        font-family: 'Inter', -apple-system, sans-serif;
        color: #475569;
        line-height: 1.8;
    }
    .sl-content-body h1, .sl-content-body h2, .sl-content-body h3 {
        color: #1e293b;
        font-weight: 800;
        margin-top: 2.5rem;
        margin-bottom: 1.25rem;
    }
    .sl-content-body h3 {
        font-size: 1.4rem;
        position: relative;
        padding-left: 20px;
        border-left: 4px solid #0ea5e9;
    }
    .sl-content-body p { margin-bottom: 1.5rem; }
    .sl-content-body strong { color: #0f172a; font-weight: 700; }
    
    .sl-content-body blockquote, .sl-content-body .ai-note {
        background: #f0f9ff;
        border-left: 4px solid #0ea5e9;
        padding: 24px;
        border-radius: 16px;
        margin: 2rem 0;
        color: #0369a1;
        font-style: italic;
        box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
    }
</style>

<div class="sl-lesson-container">
    <div class="container-xxl">
        <div class="mb-5 reveal">
            <div class="d-flex align-items-center gap-2 mb-2">
                <a asp-action="CourseDetail" asp-route-id="@Model.CourseId" class="text-decoration-none text-muted small"><i class="fa-solid fa-arrow-left"></i> Khóa học</a>
                <span class="sl-badge">Silicon Light Experience</span>
            </div>
            <h1 class="display-5 sl-text-gradient mb-0">@Model.Title</h1>
        </div>

        <div class="row g-5">
            <div class="col-xl-9">
                <!-- VIDEO -->
                <div class="sl-video-canvas mb-5">
                    @if (!string.IsNullOrEmpty(embedUrl)) {
                        <div class="ratio ratio-16x9">
                            <iframe src="@embedUrl?autoplay=0&rel=0" title="@Model.Title" frameborder="0" allowfullscreen></iframe>
                        </div>
                    } else {
                        <div class="d-flex flex-column align-items-center justify-content-center shimmer-bg ratio ratio-16x9">
                            <i class="fa-solid fa-play-circle display-1 text-muted opacity-25 mb-4"></i>
                            <h5 class="text-muted fw-bold">CHỜ ĐỢI VIDEO TẢI LÊN...</h5>
                        </div>
                    }
                </div>

                <!-- QUIZ AREA -->
                @if (exams.Any()) {
                    <div class="sl-glass-card mb-5" style="border-left: 6px solid #0ea5e9;">
                        <div class="row align-items-center">
                            <div class="col-md-8">
                                <h4 class="fw-bold mb-2">🚀 Thử thách trí tuệ!</h4>
                                <p class="text-muted mb-0">Bạn đã xem kỹ video chứ? Hãy thử sức ngay với bài tập củng cố này.</p>
                            </div>
                            <div class="col-md-4 text-md-end mt-4 mt-md-0">
                                @foreach(var exam in exams) {
                                    <a asp-controller="StudentQuiz" asp-action="Take" asp-route-id="@exam.Id" class="sl-btn-vibrant">
                                        LÀM BÀI TẬP (QUIZ) <i class="fa-solid fa-bolt ms-1"></i>
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }

                <!-- CONTENT -->
                <div class="sl-glass-card shadow-sm mb-5">
                    <ul class="nav nav-pills mb-4 gap-3">
                        <li class="nav-item">
                            <button class="nav-link active rounded-pill px-4" data-bs-toggle="pill" data-bs-target="#desc">Mô tả bài học</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link rounded-pill px-4" data-bs-toggle="pill" data-bs-target="#files">Tài liệu</button>
                        </li>
                    </ul>
                    <div class="tab-content">
                        <div class="tab-pane fade show active" id="desc">
                            <div class="lh-lg sl-content-body">
                                @Html.Raw(ViewBag.ContentHTML ?? "<p class='italic opacity-50'>Đang cập nhật nội dung văn bản...</p>")
                            </div>
                        </div>
                        <div class="tab-pane fade" id="files">
                             <div class="text-center py-4 bg-light rounded-4">
                                 <i class="fa-solid fa-folder-open display-4 text-muted mb-2"></i>
                                 <p class="text-muted">Không có tài liệu đính kèm cho bài học này.</p>
                             </div>
                        </div>
                    </div>
                </div>

                <!-- FORUM / DISCUSSION -->
                <div class="sl-glass-card shadow-sm">
                    <div class="d-flex align-items-center gap-3 mb-4">
                         <div class="res-header-icon pass" style="width:50px; height:50px; font-size:1.5rem; margin-bottom:0;"><i class="fa-solid fa-comments"></i></div>
                         <h4 class="fw-bold m-0 text-gradient">THẢO LUẬN LỚP HỌC</h4>
                    </div>
                    <div id="forumContainer">
                         <div class="text-center py-5">
                             <div class="spinner-border text-primary" role="status"></div>
                             <p class="mt-2 text-muted">ĐANG TẢI THẢO LUẬN...</p>
                         </div>
                    </div>
                </div>

                <!-- NAV BUTTONS -->
                <div class="d-flex justify-content-between align-items-center mt-5 mb-5">
                    @if (prevId.HasValue) {
                        <a asp-action="Lesson" asp-route-id="@prevId" class="btn btn-outline-secondary px-4 rounded-pill"><i class="fa-solid fa-chevron-left me-2"></i> Bài trước</a>
                    } else { <div></div> }

                    <div class="d-flex gap-3">
                        @if (ViewBag.IsLastInChapter == true)
                        {
                            <button class="btn btn-success px-4 rounded-pill fw-bold" onclick="markCompleted()">KẾT THÚC NỘI DUNG CHƯƠNG <i class="fa-solid fa-flag-checkered ms-1"></i></button>
                        }
                        else if (ViewBag.HasQuiz == false)
                        {
                            <button class="btn btn-outline-success px-4 rounded-pill fw-bold disabled">ĐÃ HOÀN THÀNH <i class="fa-solid fa-check ms-1"></i></button>
                        }
                        
                        @if (nextId.HasValue) {
                            <a asp-action="Lesson" asp-route-id="@nextId" class="btn btn-primary px-4 rounded-pill">Tiếp tục <i class="fa-solid fa-chevron-right ms-2"></i></a>
                        }
                    </div>
                </div>
            </div>

            <!-- SIDEBAR -->
            <div class="col-xl-3">
                <div class="sl-glass-card p-4 sticky-top" style="top: 100px;">
                    <h6 class="sl-text-gradient opacity-75 small fw-bold mb-1">NỘI DUNG CHƯƠNG TRÌNH</h6>
                    <h5 class="fw-extrabold mb-4 text-dark">@ViewBag.ChapterTitle</h5>
                    
                    <div class="overflow-auto ms-n2 pe-2" style="max-height: 60vh;">
                        @for (int i = 0; i < allLessons.Count; i++) {
                            var l = allLessons[i];
                            bool isCur = l.Id == Model.Id;
                            <a asp-action="Lesson" asp-route-id="@l.Id" class="sl-lesson-item @(isCur ? "active" : "")">
                                <span class="opacity-50">@(i+1).</span>
                                <div class="small">@l.Title</div>
                                @if (isCur) { <i class="fa-solid fa-play text-primary ms-auto"></i> }
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function markCompleted() {
            const btn = event.currentTarget;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Loading...';
            try {
                const response = await fetch('@Url.Action("CompleteLesson", new { id = Model.Id })', { method: 'POST' });
                if (response.ok) {
                    btn.innerHTML = 'ĐÃ XONG! 🚀';
                    btn.className = 'btn btn-outline-success px-4 rounded-pill fw-bold';
                    @if (nextId.HasValue) {
                        <text>setTimeout(() => window.location.href='@Url.Action("Lesson", new { id = nextId })', 1000);</text>
                    }
                }
            } catch(e) {}
        }

        function scrollToBottom() {
            const area = document.getElementById('forumScrollArea');
            if (area) area.scrollTop = area.scrollHeight;
        }

        async function postForumMessage() {
            const input = document.getElementById('forumInput');
            if (!input) return;
            const content = input.value.trim();
            if (!content) return;

            input.value = ''; // Reset input
            input.disabled = true;

            try {
                const formData = new FormData();
                formData.append('courseId', '@Model.CourseId');
                formData.append('content', content);

                const response = await fetch('@Url.Action("SendMessage", "CourseForum")', {
                    method: 'POST',
                    body: formData
                });

                if (response.ok) {
                    const html = await response.text();
                    document.getElementById('forumContainer').innerHTML = html;
                    scrollToBottom();
                }
            } catch(e) { console.error("Post failed:", e); }
            finally { 
                input.disabled = false; 
                input.focus(); 
            }
        }

        async function loadForum() {
            const container = document.getElementById('forumContainer');
            try {
                const response = await fetch('@Url.Action("GetMessages", "CourseForum", new { courseId = Model.CourseId })');
                if (response.ok) {
                    container.innerHTML = await response.text();
                    scrollToBottom();
                } else {
                    const errorText = await response.text();
                    container.innerHTML = '<div class="alert alert-danger"><strong>Lỗi server:</strong> 500 Internal Server Error. <br>Vui lòng kiểm tra màn hình console (dotnet run) để xem chi tiết lỗi Database (ví dụ như thiếu bảng CourseForumMessages).</div>';
                    console.error("HTTP Error", response.status, errorText);
                }
            } catch(e) { 
                container.innerHTML = '<div class="alert alert-danger">Lỗi kết nối mạng: ' + e.message + '</div>';
                console.error("Forum load failed:", e); 
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            loadForum(); // Tự động tải thảo luận khi vào bài học
        });
    </script>
}
