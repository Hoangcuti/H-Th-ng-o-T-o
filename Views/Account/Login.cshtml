@model COTHUYPRO.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="auth-bg h-vignette d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="auth-card reveal active p-5" style="max-width: 480px; width: 100%;">
        <div class="text-center mb-5">
            <div class="brand justify-content-center mb-4">
                <div class="mark rotate-subtle"><i class="fa-solid fa-graduation-cap"></i></div>
            </div>
            <h1 class="fw-bold mb-2 h2">Chào mừng trở lại</h1>
            <p class="text-muted small">Đăng nhập để quản lý và học tập ngay hôm nay.</p>
        </div>

        @if (TempData["Registered"] != null)
        {
            <div class="alert alert-success border-0 px-4 py-3 mb-4 text-center" style="border-radius: 12px; font-size: 0.85rem;">
                <i class="fa-solid fa-circle-check me-2"></i> @TempData["Registered"]
            </div>
        }

        <form asp-action="Login" method="post" class="auth-form">
            <div class="mb-4">
                <label class="form-label small fw-bold text-muted">Tên đăng nhập</label>
                <div class="input-group-custom">
                    <i class="fa-solid fa-user icon"></i>
                    <input asp-for="Username" class="form-control" placeholder="username của bạn" autocomplete="username" />
                </div>
                <span class="text-danger x-small" asp-validation-for="Username"></span>
            </div>
            
            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center">
                    <label class="form-label small fw-bold text-muted">Mật khẩu</label>
                    <a href="#" class="x-small fw-bold text-primary text-decoration-none">Quên mật khẩu?</a>
                </div>
                <div class="input-group-custom">
                    <i class="fa-solid fa-lock icon"></i>
                    <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
                </div>
                <span class="text-danger x-small" asp-validation-for="Password"></span>
            </div>

            <div class="d-flex align-items-center justify-content-between mb-4">
                <div class="form-check custom-check">
                    <input asp-for="RememberMe" class="form-check-input" id="remember" />
                    <label class="form-check-label ms-2 small text-muted" for="remember">Ghi nhớ đăng nhập</label>
                </div>
            </div>

            <button class="btn solid w-100 py-3 fw-bold mb-4" type="submit">
                Đăng nhập ngay <i class="fa-solid fa-arrow-right-to-bracket ms-2"></i>
            </button>
            
            <div class="text-center">
                <p class="text-muted small">
                    Chưa có tài khoản? <a asp-action="Register" class="text-primary fw-bold text-decoration-none">Đăng ký thành viên</a>
                </p>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
