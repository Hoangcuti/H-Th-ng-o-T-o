@model COTHUYPRO.Models.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="auth-bg h-vignette d-flex align-items-center justify-content-center py-5">
    <div class="auth-card p-5" style="max-width: 650px; width: 100%;">
        <div class="text-center mb-5">
            <div class="brand justify-content-center mb-4">
                <div class="mark rotate-subtle"><i class="fa-solid fa-graduation-cap"></i></div>
            </div>
            <h1 class="fw-bold mb-2 h2">Gia nhập cộng đồng</h1>
            <p class="text-muted small">Tạo tài khoản để bắt đầu hành trình chinh phục kiến thức mới.</p>
        </div>

        <form asp-action="Register" method="post" class="auth-form">
            <div class="row">
                <div class="col-md-6 mb-4">
                    <label class="form-label small fw-bold text-muted">Tên đăng nhập</label>
                    <div class="input-group-custom">
                        <i class="fa-solid fa-user-tag icon"></i>
                        <input asp-for="Username" class="form-control" placeholder="username" />
                    </div>
                    <span class="text-danger x-small" asp-validation-for="Username"></span>
                </div>
                <div class="col-md-6 mb-4">
                    <label class="form-label small fw-bold text-muted">Họ và tên</label>
                    <div class="input-group-custom">
                        <i class="fa-solid fa-user icon"></i>
                        <input asp-for="FullName" class="form-control" placeholder="Họ tên của bạn" />
                    </div>
                    <span class="text-danger x-small" asp-validation-for="FullName"></span>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label small fw-bold text-muted">Email liên hệ</label>
                <div class="input-group-custom">
                    <i class="fa-solid fa-envelope icon"></i>
                    <input asp-for="Email" class="form-control" placeholder="example@company.com" />
                </div>
                <span class="text-danger x-small" asp-validation-for="Email"></span>
            </div>

            <div class="mb-4">
                <label class="form-label small fw-bold text-muted">Số điện thoại</label>
                <div class="input-group-custom">
                    <i class="fa-solid fa-phone icon"></i>
                    <input asp-for="Phone" class="form-control" placeholder="09xx xxx xxx" />
                </div>
                <span class="text-danger x-small" asp-validation-for="Phone"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-4">
                    <label class="form-label small fw-bold text-muted">Mật khẩu</label>
                    <div class="input-group-custom">
                        <i class="fa-solid fa-lock icon"></i>
                        <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" />
                    </div>
                    <span class="text-danger x-small" asp-validation-for="Password"></span>
                </div>
                <div class="col-md-6 mb-4">
                    <label class="form-label small fw-bold text-muted">Xác nhận lại</label>
                    <div class="input-group-custom">
                        <i class="fa-solid fa-lock-open icon"></i>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••••" />
                    </div>
                    <span class="text-danger x-small" asp-validation-for="ConfirmPassword"></span>
                </div>
            </div>

            <div class="mb-4">
                <div class="form-check custom-check">
                    <input class="form-check-input" type="checkbox" id="terms" required>
                    <label class="form-check-label ms-2 x-small text-muted" for="terms">
                        Tôi đồng ý với các <a href="#" class="text-primary fw-bold text-decoration-none">Điều khoản & Bảo mật</a>.
                    </label>
                </div>
            </div>

            <button class="btn solid w-100 py-3 fw-bold mb-4" type="submit">Đăng ký thành viên mới</button>
            
            <div class="text-center">
                <p class="text-muted small">
                    Đã có tài khoản? <a asp-action="Login" class="text-primary fw-bold text-decoration-none">Đăng nhập ngay</a>
                </p>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
