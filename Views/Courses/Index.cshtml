@model IEnumerable<COTHUYPRO.Models.Course>
@{
    ViewData["Title"] = "Khóa học";
}

<section class="panel container-xxl animate-fade-in">
    <div class="panel-header">
        <div>
            <p class="label">Catalog</p>
            <h2 class="section-title">Chọn khóa học & đăng ký</h2>
            <p class="section-sub">Thanh toán online (demo). Chat AI đã tách sang trang riêng.</p>
        </div>
    </div>
    <div class="course-grid delay-100 animate-fade-in" style="animation-fill-mode: both;">
        @foreach (var c in Model)
        {
            var price = 1200000 + c.Id * 150000;
            <div class="course-card">
                <div class="course-meta">
                    <span class="badge">@c.Category?.Name ?? "Danh mục"</span>
                    <span class="level">@c.Level?.Name ?? "Cấp độ"</span>
                </div>
                <h3>@c.CourseName</h3>
                <p class="muted">Giảng viên: @string.Join(", ", c.Instructors.Select(i => i.User?.FullName ?? i.User?.Username ?? "N/A"))</p>
                <div class="price-tag big mt-2 mb-3 text-gradient">@String.Format("{0:#,0} đ", price)</div>
                <div class="card-actions mt-auto">
                    <a class="btn solid w-100" asp-action="Details" asp-route-id="@c.Id">Xem & đăng ký</a>
                </div>
            </div>
        }
    </div>
</section>
