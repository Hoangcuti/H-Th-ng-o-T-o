@model COTHUYPRO.Models.StudentsPageVm
@{
    ViewData["Title"] = "Quản lý học viên";
}

<div class="page-header">
    <div>
        <p class="eyebrow">Học viên</p>
        <h2>Quản lý học viên</h2>
        <p class="muted">Theo dõi tiến độ, điểm và chứng chỉ (LearningProgress).</p>
    </div>
</div>

<div class="panel-card">
    <div class="panel-head">
        <h4>Danh sách học viên</h4>
        <span class="pill muted">@Model.Students.Count học viên</span>
    </div>
    <div class="table-wrapper">
        <table class="table table-borderless align-middle admin-table">
            <thead>
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                    <th>Mã SV</th>
                    <th>Họ tên</th>
                    <th>Các khóa đang học</th>
                    <th class="text-center">Số khóa HT</th>
                    <th class="text-end">Ngày tạo</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var s in Model.Students)
            {
                <tr style="border-bottom: 1px solid rgba(255,255,255,0.02);">
                    <td><span class="badge" style="background: rgba(16, 185, 129, 0.1); color: #10b981;">@s.StudentCode</span></td>
                    <td class="fw-semibold text-white">
                        @s.User.FullName
                        <div class="muted" style="font-size: 0.8rem; font-weight: normal;">@s.User.Username</div>
                    </td>
                    <td>
                        @if (s.EnrolledCourses.Any())
                        {
                            <div class="d-flex flex-wrap gap-1">
                                @foreach (var c in s.EnrolledCourses)
                                {
                                    <span class="badge" style="background: rgba(6,182,212,0.1); color: var(--primary); font-size: 0.75rem;">@c</span>
                                }
                            </div>
                        }
                        else
                        {
                            <span class="muted" style="font-size: 0.85rem;">Chưa đăng ký</span>
                        }
                    </td>
                    <td class="text-center">@s.CompletedCourses</td>
                    <td class="text-end muted" style="font-size: 0.85rem;">@s.User.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
