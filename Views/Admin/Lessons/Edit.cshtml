@model COTHUYPRO.Models.LessonFormVm
@{
    ViewData["Title"] = "Chỉnh sửa bài giảng";
    var courses = ViewBag.Courses as List<COTHUYPRO.Models.Course> ?? new();
}

<div class="page-header">
    <div>
        <p class="eyebrow">Bài giảng</p>
        <h2>Chỉnh sửa bài giảng</h2>
    </div>
</div>

<div class="panel-card">
    <div class="panel-head"><h4>Thông tin</h4></div>
    <form asp-action="EditLesson" method="post" enctype="multipart/form-data" class="row g-3">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <div class="col-md-6">
            <label class="form-label">Tiêu đề</label>
            <input asp-for="Title" class="form-control" />
            <span class="text-danger" asp-validation-for="Title"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label">Khóa học</label>
            <select asp-for="CourseId" class="form-select">
                @foreach (var c in courses) { <option value="@c.Id" selected="@(Model.CourseId==c.Id)">@c.CourseName</option> }
            </select>
        </div>
        <div class="col-md-6">
            <label class="form-label">Thứ tự bài giảng (Order Index)</label>
            <input asp-for="OrderIndex" class="form-control" type="number" />
            <span class="text-danger" asp-validation-for="OrderIndex"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label">Thời lượng (Phút)</label>
            <input asp-for="Duration" class="form-control" type="number" />
            <span class="text-danger" asp-validation-for="Duration"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label">Tài liệu bài giảng (File Word/PDF hoặc URL)</label>
            <div class="input-group">
                <input type="file" asp-for="DocumentFile" class="form-control" accept=".pdf,.doc,.docx,.ppt,.pptx" />
                <input asp-for="DocumentUrl" class="form-control" placeholder="Hoặc dán URL tài liệu..." />
            </div>
            <span class="text-danger" asp-validation-for="DocumentFile"></span>
            <span class="text-danger" asp-validation-for="DocumentUrl"></span>
            @if(!string.IsNullOrEmpty(Model.DocumentUrl)) {
                <div class="mt-1"><small class="text-muted">Hiện tại: <a href="@Model.DocumentUrl" target="_blank">Xem tài liệu</a></small></div>
            }
        </div>
        <div class="col-md-6">
            <label class="form-label">Link Video (YouTube/Vimeo)</label>
            <input asp-for="VideoUrl" class="form-control" placeholder="https://..." oninput="updateVideoPreview(this.value)" />
            <span class="text-danger" asp-validation-for="VideoUrl"></span>
            <div id="videoPreviewContainer" class="mt-3" style="display:none;">
                <div class="ratio ratio-16x9 border rounded overflow-hidden shadow-sm">
                    <iframe id="videoPreviewFrame" src="" allowfullscreen></iframe>
                </div>
            </div>
        </div>
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-end mb-2">
                <label class="form-label mb-0">Nội dung văn bản chi tiết</label>
                <button type="button" class="btn btn-sm btn-outline-info fw-bold" onclick="generateAiLesson(event)">✨ AI Soạn Nội Dung</button>
            </div>
            <textarea asp-for="Content" class="form-control" rows="5" placeholder="Hỗ trợ HTML..."></textarea>
            <span class="text-danger" asp-validation-for="Content"></span>
        </div>
        <div class="col-md-6">
            <div class="form-check mt-md-4">
                <input class="form-check-input" type="checkbox" asp-for="IsFreePreview">
                <label class="form-check-label text-success fw-bold">
                    Cho phép học thử miễn phí (Free Preview)
                </label>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-check mt-md-4">
                <input class="form-check-input" type="checkbox" asp-for="IsPublished">
                <label class="form-check-label fw-bold">
                    Xuất bản hiển thị (Publish)
                </label>
            </div>
        </div>
        <div class="col-12 d-flex gap-2">
            <button class="btn solid" type="submit">Lưu</button>
            <a class="btn ghost" asp-action="Lessons">Hủy</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    async function generateAiLesson(e) {
        var topic = prompt("Nhập chủ đề bài giảng để Trợ lý AI tự động soạn thảo:");
        if(!topic) return;
        
        var btn = e.target;
        var originalText = btn.innerHTML;
        btn.innerHTML = "⏳ Đang soạn...";
        btn.disabled = true;
        
        try {
            var res = await fetch('/Admin/GenerateLessonContent', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ topic: topic })
            });
            var data = await res.json();
            if(data.success) {
                document.getElementById('Content').value = data.content;
                alert("✨ Đã soạn xong bài! Vui lòng đọc qua và chỉnh sửa lại trước khi lưu nhé.");
            }
        } catch(err) {
            alert("Lỗi kết nối AI trợ giảng.");
        } finally {
            btn.innerHTML = originalText;
            btn.disabled = false;
        }
    }

    function updateVideoPreview(url) {
        const container = document.getElementById('videoPreviewContainer');
        const iframe = document.getElementById('videoPreviewFrame');
        
        if (!url) {
            container.style.display = 'none';
            return;
        }

        let embedUrl = "";
        if (url.includes("youtube.com/watch?v=")) {
            const id = url.split("v=")[1].split("&")[0];
            embedUrl = `https://www.youtube.com/embed/${id}`;
        } else if (url.includes("youtu.be/")) {
            const id = url.split("youtu.be/")[1].split("?")[0];
            embedUrl = `https://www.youtube.com/embed/${id}`;
        } else if (url.includes("vimeo.com/")) {
            const id = url.split("vimeo.com/")[1].split("?")[0];
            embedUrl = `https://player.vimeo.com/video/${id}`;
        }

        if (embedUrl) {
            iframe.src = embedUrl;
            container.style.display = 'block';
        } else {
            container.style.display = 'none';
        }
    }

    // Auto-check on load if URL exists
    window.addEventListener('DOMContentLoaded', () => {
        const val = document.getElementById('VideoUrl').value;
        if (val) updateVideoPreview(val);
    });
    </script>
}
