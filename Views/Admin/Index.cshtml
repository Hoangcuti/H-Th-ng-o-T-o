@model COTHUYPRO.Models.AdminIndexViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <div>
        <p class="eyebrow">Cập nhật theo thời gian thực</p>
        <h2>Quản trị hệ thống</h2>
        <p class="muted">Tổng quan số liệu, người dùng và khóa học mới nhất.</p>
    </div>
    <div class="quick-actions">
        <a class="btn ghost" asp-controller="Courses" asp-action="Index">Xem danh sách khóa</a>
        <a class="btn solid" asp-controller="Chat" asp-action="Index">Chat AI hỗ trợ</a>
    </div>
</div>

<div class="stat-grid animate-fade-in delay-100" style="animation-fill-mode: both;">
    <div class="stat-card primary">
        <p>Người dùng</p>
        <h3>@Model.Stats.UserCount</h3>
        <span class="muted">Tổng tài khoản đang hoạt động</span>
    </div>
    <div class="stat-card">
        <p>Khóa học</p>
        <h3>@Model.Stats.CourseCount</h3>
        <span class="muted">Đang mở cho đăng ký</span>
    </div>
    <div class="stat-card">
        <p>Lớp học</p>
        <h3>@Model.Stats.ClassCount</h3>
        <span class="muted">Lịch học đã xếp</span>
    </div>
    <div class="stat-card">
        <p>Khóa đã bán</p>
        <h3>@Model.Stats.SoldCourseCount</h3>
        <span class="muted">Lượt học viên đăng ký</span>
    </div>
    <div class="stat-card accent">
        <p>Chứng chỉ chờ</p>
        <h3>@Model.Stats.PendingCertificates</h3>
        <span class="muted">Cần duyệt và cấp phát</span>
    </div>
    <div class="stat-card primary">
        <p>Doanh thu</p>
        <h3>@string.Format("{0:N0} đ", Model.Stats.TotalRevenue)</h3>
        <span class="muted">Dựa trên giá khóa học thực tế</span>
    </div>
</div>

<div class="row g-4 animate-fade-in delay-150" style="animation-fill-mode: both; margin: 24px 0;">
    <div class="col-lg-8">
        <div class="panel-card h-100">
            <div class="panel-head">
                <div>
                    <p class="eyebrow">Phân tích</p>
                    <h4>Biểu đồ Tăng trưởng (Người dùng & Khóa học)</h4>
                </div>
            </div>
            <div style="height: 320px; width: 100%; position: relative;">
                <canvas id="growthChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="panel-card h-100">
            <div class="panel-head">
                <div>
                    <p class="eyebrow">Cơ cấu</p>
                    <h4>Phân loại người dùng</h4>
                </div>
            </div>
            <div style="height: 320px; width: 100%; position: relative; padding: 20px;">
                <canvas id="userTypeChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="panel-grid animate-fade-in delay-200" style="animation-fill-mode: both;">
    <div class="panel-card">
        <div class="panel-head">
            <div>
                <p class="eyebrow">Nhân sự</p>
                <h4>Người dùng mới</h4>
            </div>
            <span class="pill muted">Tổng @Model.RecentUsers.Count</span>
        </div>
        <div class="table-wrapper">
            <table class="table table-borderless align-middle admin-table">
                <thead>
                    <tr>
                        <th>Tài khoản</th>
                        <th>Họ tên</th>
                        <th>Vai trò</th>
                        <th>Ngày tạo</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var u in Model.RecentUsers)
                {
                    <tr>
                        <td class="fw-semibold">@u.Username</td>
                        <td>@u.FullName</td>
                        <td>
                            <span class="pill">@string.Join(" · ", u.UserRoles.Select(ur => ur.Role!.Name == "Instructor" ? "Giảng viên" : (ur.Role!.Name == "Student" ? "Học viên" : ur.Role!.Name)))</span>
                        </td>
                        <td class="muted">@u.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="panel-card">
        <div class="panel-head">
            <div>
                <p class="eyebrow">Nội dung</p>
                <h4>Khóa học mới</h4>
            </div>
            <span class="pill muted">Tổng @Model.RecentCourses.Count</span>
        </div>
        <div class="course-tiles">
            @foreach (var c in Model.RecentCourses)
            {
                <div class="course-tile">
                    <div class="meta">
                        <span class="tag">@c.Category?.Name</span>
                        <span class="tag ghost">@c.Level?.Name</span>
                    </div>
                    <h5>@c.CourseName</h5>
                    <p class="muted">ID: @c.Id</p>
                </div>
            }
        </div>
    </div>

    <div class="panel-card">
        <div class="panel-head">
            <div>
                <p class="eyebrow">Kinh doanh</p>
                <h4>Top khóa học & doanh thu</h4>
            </div>
            <span class="pill muted">Demo</span>
        </div>
        <div class="table-wrapper">
            <table class="table table-borderless align-middle admin-table">
                <thead>
                    <tr>
                        <th>Khóa học</th>
                        <th>Học viên</th>
                        <th>Doanh thu</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var top in Model.TopCourses)
                    {
                        <tr>
                            <td class="fw-semibold">@top.CourseName</td>
                            <td class="muted">@top.Learners người</td>
                            <td class="muted">@string.Format("{0:N0} đ", top.Revenue)</td>
                        </tr>
                    }
                    @if (!Model.TopCourses.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center muted">Chưa có dữ liệu học viên đăng ký khóa học.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="panel-card management-board animate-fade-in delay-300" style="animation-fill-mode: both;">
    <div class="panel-head">
        <div>
            <p class="eyebrow">Điều hướng nhanh</p>
            <h4>Module quản lý</h4>
        </div>
    </div>
    <div class="mg-grid">
        <div class="mg-item">
            <div class="title">Khóa học</div>
            <p class="muted">Tạo/sửa khóa, phân danh mục & cấp độ.</p>
            <a asp-controller="Admin" asp-action="Courses" class="pill">Đi tới</a>
        </div>
        <div class="mg-item">
            <div class="title">QL tài khoản</div>
            <p class="muted">Phân quyền Admin / Giảng viên / Học viên.</p>
            <a asp-controller="Admin" asp-action="Accounts" class="pill">Đi tới</a>
        </div>
        <div class="mg-item">
            <div class="title">QL học viên</div>
            <p class="muted">Theo dõi tiến độ, điểm và chứng chỉ.</p>
            <a asp-controller="Admin" asp-action="Students" class="pill">Đi tới</a>
        </div>
        <div class="mg-item">
            <div class="title">QL giảng viên</div>
            <p class="muted">Phân công giảng dạy, tải tài nguyên.</p>
            <a asp-controller="Admin" asp-action="Instructors" class="pill">Đi tới</a>
        </div>
        <div class="mg-item">
            <div class="title">QL bài giảng</div>
            <p class="muted">Nội dung, video, tài liệu đính kèm.</p>
            <a asp-controller="Admin" asp-action="Lessons" class="pill">Đi tới</a>
        </div>
        <div class="mg-item">
            <div class="title">QL bài Quiz</div>
            <p class="muted">Ngân hàng câu hỏi, chấm tự động.</p>
            <a asp-controller="Admin" asp-action="Quiz" class="pill">Đi tới</a>
        </div>
        <div class="mg-item">
            <div class="title">QL mã giảm giá</div>
            <p class="muted">Mã coupon, thời hạn, điều kiện áp dụng.</p>
            <a asp-controller="Admin" asp-action="Discounts" class="pill">Đi tới</a>
        </div>
        <div class="mg-item">
            <div class="title">Doanh thu & thống kê</div>
            <p class="muted">Khóa học hot, số học viên, doanh thu.</p>
            <a asp-controller="Admin" asp-action="Revenue" class="pill">Đi tới</a>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const ctx = document.getElementById('growthChart').getContext('2d');
            
            // Generate a gradient for the chart
            let gradientPrimary = ctx.createLinearGradient(0, 0, 0, 400);
            gradientPrimary.addColorStop(0, 'rgba(6, 182, 212, 0.5)');   
            gradientPrimary.addColorStop(1, 'rgba(6, 182, 212, 0.05)');
            
            let gradientAccent = ctx.createLinearGradient(0, 0, 0, 400);
            gradientAccent.addColorStop(0, 'rgba(245, 158, 11, 0.5)');   
            gradientAccent.addColorStop(1, 'rgba(245, 158, 11, 0.05)');

            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['T1', 'T2', 'T3', 'T4', 'T5', 'T6', 'T7'],
                    datasets: [
                        {
                            label: 'Người dùng mới',
                            data: [12, 19, 25, 32, 45, 60, @Model.Stats.UserCount],
                            borderColor: '#06b6d4',
                            backgroundColor: gradientPrimary,
                            borderWidth: 2,
                            tension: 0.4,
                            fill: true,
                            pointBackgroundColor: '#0f172a',
                            pointBorderColor: '#06b6d4',
                            pointBorderWidth: 2,
                            pointRadius: 4,
                            pointHoverRadius: 6
                        },
                        {
                            label: 'Khóa học mới',
                            data: [2, 5, 8, 11, 15, 20, @Model.Stats.CourseCount],
                            borderColor: '#f59e0b',
                            backgroundColor: gradientAccent,
                            borderWidth: 2,
                            tension: 0.4,
                            fill: true,
                            pointBackgroundColor: '#0f172a',
                            pointBorderColor: '#f59e0b',
                            pointBorderWidth: 2,
                            pointRadius: 4,
                            pointHoverRadius: 6
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            labels: {
                                color: '#94a3b8',
                                font: { family: "'Space Grotesk', sans-serif", size: 13, weight: 600 }
                            }
                        },
                        tooltip: {
                            backgroundColor: 'rgba(15, 23, 42, 0.9)',
                            titleColor: '#fff',
                            bodyColor: '#e2e8f0',
                            borderColor: 'rgba(255,255,255,0.1)',
                            borderWidth: 1,
                            padding: 12,
                            cornerRadius: 8,
                            displayColors: true
                        }
                    },
                    scales: {
                        x: {
                            grid: { color: 'rgba(255, 255, 255, 0.05)', drawBorder: false },
                            ticks: { color: '#94a3b8', font: { family: "'Space Grotesk', sans-serif" } }
                        },
                        y: {
                            grid: { color: 'rgba(255, 255, 255, 0.05)', drawBorder: false },
                            ticks: { color: '#94a3b8', font: { family: "'Space Grotesk', sans-serif" } },
                            beginAtZero: true
                        }
                    },
                    interaction: {
                        mode: 'index',
                        intersect: false
                    }
                }
            new Chart(ctx, {
                // ... (line 227)
            });

            // New User Type Pie Chart
            const ctxPie = document.getElementById('userTypeChart').getContext('2d');
            
            // Lấy dữ liệu từ Table (tạm thời) hoặc từ Model
            const studentCount = @Model.RecentUsers.Count(u => u.UserRoles.Any(ur => ur.Role!.Name == "Student"));
            const instructorCount = @Model.RecentUsers.Count(u => u.UserRoles.Any(ur => ur.Role!.Name == "Instructor"));
            const adminCount = @Model.RecentUsers.Count(u => u.UserRoles.Any(ur => ur.Role!.Name == "Admin"));

            new Chart(ctxPie, {
                type: 'doughnut',
                data: {
                    labels: ['Học viên', 'Giảng viên', 'Admin'],
                    datasets: [{
                        data: [studentCount, instructorCount, adminCount],
                        backgroundColor: ['#06b6d4', '#f59e0b', '#6366f1'],
                        borderWidth: 0,
                        hoverOffset: 10
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                color: '#94a3b8',
                                padding: 20,
                                font: { family: "'Space Grotesk', sans-serif", size: 12 }
                            }
                        }
                    }
                }
            });
        });
    </script>
}
