@model COTHUYPRO.Models.AdminIndexViewModel
@{
    ViewData["Title"] = "Bảng điều khiển";
}

<!-- STATS SECTION -->
<div class="stat-grid animate-up" style="animation-delay: 0.1s;">
    <div class="stat-card primary">
        <div class="stat-info">
            <p>Học viên</p>
            <h3>@Model.Stats.UserCount</h3>
        </div>
        <div class="stat-meta">
            <i class="bi bi-person-badge-fill"></i>
            <span>Tài khoản hệ thống</span>
        </div>
    </div>
    
    <div class="stat-card accent">
        <div class="stat-info">
            <p>Doanh thu (Thực tế)</p>
            <h3>@string.Format("{0:N0}", Model.Stats.TotalRevenue)đ</h3>
        </div>
        <div class="stat-meta">
            <i class="bi bi-wallet2"></i>
            <span>Dựa trên lượt đăng ký</span>
        </div>
    </div>

    <div class="stat-card warning">
        <div class="stat-info">
            <p>Khóa học</p>
            <h3>@Model.Stats.CourseCount</h3>
        </div>
        <div class="stat-meta">
            <i class="bi bi-journal-check"></i>
            <span>Chương trình đào tạo</span>
        </div>
    </div>

    <div class="stat-card success">
        <div class="stat-info">
            <p>Lượt đăng ký</p>
            <h3>@Model.Stats.SoldCourseCount</h3>
        </div>
        <div class="stat-meta">
            <i class="bi bi-cart-check"></i>
            <span>Học viên tham gia</span>
        </div>
    </div>

    <div class="stat-card info">
        <div class="stat-info">
            <p>Tiến độ học tập</p>
            <h3>@string.Format("{0:F1}", Model.Stats.AvgStudentProgress)%</h3>
        </div>
        <div class="stat-meta">
            <i class="bi bi-graph-up-arrow"></i>
            <span>Trung bình hệ thống</span>
        </div>
    </div>
</div>

<!-- CHARTS SECTION -->
<div class="row g-4 mb-5 animate-up" style="animation-delay: 0.2s;">
    <div class="col-lg-8">
        <div class="panel-card h-100">
            <div class="panel-head">
                <div>
                    <h4 class="mb-1">Doanh thu & Tăng trưởng</h4>
                    <p class="text-muted small m-0">Thống kê thực tế theo từng tháng</p>
                </div>
                <div class="dropdown">
                    <button class="btn btn-sm btn-light border" type="button">Tất cả thời gian</button>
                </div>
            </div>
            <div style="height: 350px;">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="panel-card h-100">
            <div class="panel-head">
                <h4 class="m-0">Phân bổ khóa học</h4>
            </div>
            <div style="height: 350px;">
                <canvas id="coursePieChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- TABLES SECTION -->
<div class="row g-4 animate-up" style="animation-delay: 0.3s;">
    <div class="col-lg-7">
        <div class="panel-card">
            <div class="panel-head">
                <h4 class="m-0">Thành viên mới gia nhập</h4>
                <a class="btn btn-info btn-sm" asp-action="Accounts">
                    <i class="bi bi-funnel-fill"></i> Xem bộ lọc
                </a>
            </div>
            <div class="table-responsive">
                <table class="table table-borderless align-middle admin-table m-0">
                    <thead>
                        <tr class="table-header-row small fw-bold">
                            <th class="ps-3 py-3">Học viên</th>
                            <th class="py-3">Trạng thái</th>
                            <th class="text-end pe-3 py-3">Ngày tham gia</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model.RecentUsers)
                        {
                            <tr class="border-bottom">
                                <td class="py-3 ps-3">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="user-avatar shadow-sm" style="width: 32px; height: 32px; font-size:0.8rem;">@u.Username[0]</div>
                                        <div>
                                            <div class="fw-bold text-dark">@u.FullName</div>
                                            <div class="text-muted small">@@@u.Username</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-3">
                                    <span class="pill">@string.Join(" · ", u.UserRoles.Select(ur => ur.Role!.Name))</span>
                                </td>
                                <td class="text-end pe-3 py-3 text-muted small">
                                    @u.CreatedAt.ToString("dd/MM/yyyy")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    
    <div class="col-lg-5">
        <div class="panel-card h-100">
            <div class="panel-head">
                <h4 class="m-0">Top khóa học doanh thu</h4>
            </div>
            <div class="table-responsive">
                <table class="table table-borderless align-middle">
                    <tbody>
                        @foreach (var top in Model.TopCourses)
                        {
                            <tr class="border-bottom">
                                <td class="py-3">
                                    <div class="fw-bold">@top.CourseName</div>
                                    <div class="text-muted small">@top.Learners lượt đăng ký</div>
                                </td>
                                <td class="text-end py-3">
                                    <div class="fw-extrabold text-primary">@string.Format("{0:N0}", top.Revenue)đ</div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
    document.addEventListener("DOMContentLoaded", function () {
        const primaryColor = '#6366f1';
        const accentColor = '#06b6d4';
        
        // 1. REVENUE LINE CHART
        const ctxRev = document.getElementById('revenueChart').getContext('2d');
        let grad = ctxRev.createLinearGradient(0, 0, 0, 400);
        grad.addColorStop(0, 'rgba(99, 102, 241, 0.25)');
        grad.addColorStop(1, 'rgba(99, 102, 241, 0)');

        new Chart(ctxRev, {
            type: 'line',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.RevenueLabels)),
                datasets: [{
                    label: 'Doanh thu',
                    data: @Html.Raw(Json.Serialize(Model.RevenueData)),
                    borderColor: primaryColor,
                    backgroundColor: grad,
                    borderWidth: 4,
                    tension: 0.45,
                    fill: true,
                    pointBackgroundColor: '#fff',
                    pointBorderColor: primaryColor,
                    pointBorderWidth: 3,
                    pointRadius: 5,
                    pointHoverRadius: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: '#1e293b',
                        padding: 12,
                        cornerRadius: 12,
                        titleFont: { size: 14, weight: 'bold' },
                        bodyFont: { size: 13 },
                        callbacks: {
                            label: function(context) {
                                return ' Doanh thu: ' + context.parsed.y.toLocaleString() + 'đ';
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { color: '#64748b', font: { weight: '600' } }
                    },
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(0,0,0,0.04)', drawBorder: false },
                        ticks: { 
                            color: '#64748b', 
                            font: { weight: '600' },
                            callback: function(value) {
                                if (value >= 1000000) return (value/1000000) + 'tr';
                                if (value >= 1000) return (value/1000) + 'k';
                                return value;
                            }
                        }
                    }
                }
            }
        });

        // 2. COURSE PIE CHART
        const ctxPie = document.getElementById('coursePieChart').getContext('2d');
        const pieData = @Html.Raw(Json.Serialize(Model.CourseData));
        const hasPieData = pieData && pieData.length > 0 && pieData.some(d => d > 0);

        if (!hasPieData) {
            // Draw Empty State Placeholder
            new Chart(ctxPie, {
                type: 'doughnut',
                data: {
                    labels: ['Chưa có dữ liệu'],
                    datasets: [{
                        data: [1],
                        backgroundColor: ['#f1f5f9'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '75%',
                    plugins: {
                        legend: { display: false },
                        tooltip: { enabled: false }
                    }
                },
                plugins: [{
                    id: 'emptyStateText',
                    afterDraw: (chart) => {
                        const { ctx, width, height } = chart;
                        ctx.save();
                        ctx.textAlign = 'center';
                        ctx.textBaseline = 'middle';
                        ctx.font = '700 13px "Inter"';
                        ctx.fillStyle = '#94a3b8';
                        ctx.fillText('Chưa có dữ liệu', width / 2, height / 2);
                        ctx.restore();
                    }
                }]
            });
        } else {
            new Chart(ctxPie, {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.CourseLabels)),
                    datasets: [{
                        data: pieData,
                        backgroundColor: [
                            '#6366f1', '#06b6d4', '#f59e0b', '#10b981', '#ec4899', '#8b5cf6'
                        ],
                        hoverOffset: 15,
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 24,
                                usePointStyle: true,
                                font: { size: 12, weight: '700' },
                                color: '#475569'
                            }
                        }
                    }
                }
            });
        }
    });
    </script>
}
