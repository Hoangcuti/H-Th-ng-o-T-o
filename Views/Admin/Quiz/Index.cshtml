@model COTHUYPRO.Models.QuizPageVm
@{
    ViewData["Title"] = "Quản lý bài Quiz";
}

<div class="page-header">
    <div>
        <p class="eyebrow">Quiz</p>
        <h2>Quản lý bài Quiz</h2>
        <p class="muted">Dữ liệu từ bảng Exams (gắn với Course).</p>
    </div>
    <div class="quick-actions">
        <a class="btn solid" asp-action="CreateQuiz">+ Thêm bài Quiz</a>
    </div>
</div>

<div class="panel-card">
    <div class="panel-head">
        <h4>Danh sách quiz</h4>
        <span class="pill muted">@Model.Exams.Count bài</span>
    </div>
    <div class="table-wrapper">
        <table class="table table-borderless align-middle admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Tiêu đề</th>
                    <th>Khóa học</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var q in Model.Exams)
            {
                <tr>
                    <td class="fw-semibold">@q.Id</td>
                    <td class="fw-semibold">@q.Title</td>
                    <td>@q.Course?.CourseName</td>
                    <td class="d-flex gap-2">
                        <a class="btn ghost btn-sm" asp-action="EditQuiz" asp-route-id="@q.Id">✏ Sửa</a>
                        <form asp-action="DeleteQuiz" method="post" onsubmit="return confirm('Xóa bài quiz này?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@q.Id" />
                            <button class="btn btn-sm" style="background:#fee2e2; color:#b91c1c; border:1px solid #fecdd3;">🗑 Xóa</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
