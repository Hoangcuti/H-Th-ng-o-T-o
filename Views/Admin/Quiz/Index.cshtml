@model COTHUYPRO.Models.QuizPageVm
@{
    ViewData["Title"] = "Quản lý bài Quiz";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <p class="eyebrow">Quiz</p>
        <h2 class="m-0">Quản lý bài Quiz</h2>
        <p class="muted mt-1 mb-0">Dữ liệu từ bảng Exams (gắn với Course).</p>
    </div>
    <div class="quick-actions">
        <a class="btn btn-primary" asp-action="CreateQuiz">
            <i class="bi bi-plus-circle-fill"></i> Thêm bài Quiz mới
        </a>
    </div>
</div>

<div class="panel-card">
    <div class="panel-head d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-3">
            <h4 class="fw-bold m-0 text-dark">Danh sách quiz</h4>
            <span class="badge badge-primary">@Model.Exams.Count bài</span>
        </div>
        <div class="search-container" style="width: 320px;">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0" style="border-radius: 12px 0 0 12px;"><i class="bi bi-search"></i></span>
                <input type="text" id="quizSearch" class="form-control border-start-0" placeholder="Tìm tiêu đề, khóa học..." style="border-radius: 0 12px 12px 0;">
            </div>
        </div>
    </div>
    <div class="table-wrapper">
        <table id="quizTable" class="table table-borderless align-middle admin-table">
            <thead>
                <tr class="table-header-row small fw-bold">
                    <th class="px-4">ID</th>
                    <th>TIÊU ĐỀ</th>
                    <th>KHÓA HỌC</th>
                    <th class="text-end px-4">HÀNH ĐỘNG</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var q in Model.Exams)
            {
                <tr style="border-bottom: 2px solid rgba(0,0,0,0.02);">
                    <td class="px-4 fw-bold text-dark">#@q.Id</td>
                    <td>
                        <div class="fw-bold text-dark">@q.Title</div>
                    </td>
                    <td>
                        <span class="badge badge-primary">@q.Course?.CourseName</span>
                    </td>
                    <td class="text-end px-4">
                        <div class="d-flex gap-2 justify-content-end align-items-center">
                            <a class="btn btn-info btn-sm" asp-action="EditQuiz" asp-route-id="@q.Id" title="Sửa">
                                <i class="bi bi-pencil-fill"></i> Sửa
                            </a>
                            <form asp-action="DeleteQuiz" method="post" onsubmit="return confirm('Xóa bài quiz này?');" class="m-0">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@q.Id" />
                                <button class="btn btn-danger btn-sm" type="submit" title="Xóa">
                                    <i class="bi bi-trash-fill"></i> Xóa
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            applyLiveSearch('quizSearch', 'quizTable');
        });
    </script>
}
