@model COTHUYPRO.Models.ExamFormVm
@{
    ViewData["Title"] = "Tạo bài Quiz";
    var courses = ViewBag.Courses as List<COTHUYPRO.Models.Course> ?? new();
}

<div class="page-header">
    <div>
        <p class="eyebrow">Quiz</p>
        <h2>Tạo bài Quiz</h2>
    </div>
</div>

<div class="panel-card">
    <div class="panel-head"><h4>Thông tin bài Quiz</h4></div>
    <form asp-action="CreateQuiz" method="post" class="row g-3">
        @Html.AntiForgeryToken()
        <div class="col-md-6">
            <label class="form-label">Loại bài kiểm tra / Đánh giá</label>
            <select asp-for="ExamType" class="form-select">
                <option value="Quiz">Trắc nghiệm bài học (Quiz)</option>
                <option value="Final">Bài thi kết thúc khóa (Final Exam)</option>
                <option value="Midterm">Kiểm tra giữa kỳ</option>
            </select>
            <span class="text-danger" asp-validation-for="ExamType"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label">Tiêu đề (Tên bài Quiz)</label>
            <input asp-for="Title" class="form-control" placeholder="Ví dụ: Kiểm tra kiến thức Chương 1" />
            <span class="text-danger" asp-validation-for="Title"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label">Khóa học</label>
            <select asp-for="CourseId" class="form-select" id="courseSelect" onchange="filterLessons(this.value)">
                @foreach (var c in courses) { <option value="@c.Id">@c.CourseName</option> }
            </select>
            <span class="text-danger" asp-validation-for="CourseId"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label">Gắn vào bài giảng (Tùy chọn)</label>
            <select asp-for="LessonId" class="form-select" id="lessonSelect">
                <option value="">-- Chọn bài giảng (Toàn bộ khóa) --</option>
                @foreach (var l in (ViewBag.Lessons as List<COTHUYPRO.Models.Lesson> ?? new())) {
                    <option value="@l.Id" data-course="@l.CourseId">@l.Title</option>
                }
            </select>
            <span class="text-danger" asp-validation-for="LessonId"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label">Thời gian làm bài (Phút)</label>
            <input asp-for="DurationMinutes" class="form-control" type="number" />
            <span class="text-danger" asp-validation-for="DurationMinutes"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label">Điểm đỗ / qua môn (Ví dụ: 80)</label>
            <input asp-for="PassingScore" class="form-control" type="number" />
            <span class="text-danger" asp-validation-for="PassingScore"></span>
        </div>
        <div class="col-12">
            <label class="form-label">Mô tả thêm / Ghi chú</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            <span class="text-danger" asp-validation-for="Description"></span>
        </div>
        
        <div class="col-md-4">
            <label class="form-label">Số lần làm lại tối đa (0 = Vô hạn)</label>
            <input asp-for="MaxAttempts" class="form-control" type="number" />
            <span class="text-danger" asp-validation-for="MaxAttempts"></span>
        </div>
        <div class="col-md-4 mt-md-4">
            <div class="form-check mt-3">
                <input class="form-check-input" type="checkbox" asp-for="ShuffleQuestions">
                <label class="form-check-label fw-bold">Trộn câu hỏi 🔀</label>
            </div>
        </div>
        <div class="col-md-4 mt-md-4">
            <div class="form-check mt-3">
                <input class="form-check-input" type="checkbox" asp-for="ShowAnswers">
                <label class="form-check-label fw-bold">Hiện đáp án khi kết thúc 👁️</label>
            </div>
        </div>
        
        <div class="col-12 d-flex gap-2 mt-4">
            <button class="btn solid" type="submit">Tạo mới</button>
            <a class="btn ghost" asp-action="Quiz">Hủy bỏ</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function filterLessons(courseId) {
            const lessonSelect = document.getElementById('lessonSelect');
            const options = lessonSelect.querySelectorAll('option');
            
            options.forEach(opt => {
                if (opt.value === "") {
                    opt.style.display = 'block';
                    return;
                }
                const optCourseId = opt.getAttribute('data-course');
                if (optCourseId === courseId) {
                    opt.style.display = 'block';
                } else {
                    opt.style.display = 'none';
                    if (lessonSelect.value === opt.value) lessonSelect.value = "";
                }
            });
        }

        // Run on load
        window.addEventListener('DOMContentLoaded', () => {
            filterLessons(document.getElementById('courseSelect').value);
        });
    </script>
}
