@model COTHUYPRO.Models.InstructorsPageVm
@{
    ViewData["Title"] = "Quản lý giảng viên";
}

<div class="page-header">
    <div>
        <p class="eyebrow">Giảng viên</p>
        <h2>Quản lý giảng viên</h2>
        <p class="muted">Phân công giảng dạy (CourseInstructors liên kết Users).</p>
    </div>
</div>

<div class="panel-card">
    <div class="panel-head">
        <h4>Danh sách giảng viên</h4>
        <span class="pill muted">@Model.Instructors.Count người</span>
        <a class="btn solid" asp-action="CreateInstructor">➕ Thêm</a>
    </div>
    <div class="table-wrapper">
        <table class="table table-borderless align-middle admin-table">
            <thead>
                <tr>
                    <th>Họ tên</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Số khóa phụ trách</th>
                    <th>Ngày tạo</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var ins in Model.Instructors)
            {
                <tr>
                    <td class="fw-semibold">@ins.User.FullName</td>
                    <td>@ins.User.Username</td>
                    <td>@ins.User.Email</td>
                    <td>@ins.CourseCount</td>
                    <td class="muted">@ins.User.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</td>
                    <td class="d-flex gap-2">
                        <a class="btn ghost btn-sm" asp-action="EditInstructor" asp-route-id="@ins.User.Id">✏</a>
                        <form asp-action="DeleteInstructor" method="post" onsubmit="return confirm('Xóa giảng viên này?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@ins.User.Id" />
                            <button class="btn btn-sm" style="background:#fee2e2; color:#b91c1c; border:1px solid #fecdd3;">🗑</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<div class="panel-card" style="margin-top: 24px;">
    <div class="panel-head">
        <h4>Đơn đăng ký giảng dạy</h4>
        @{
            var apps = ViewBag.Applications as List<COTHUYPRO.Models.InstructorCourseApplication> ?? new();
        }
        <span class="pill muted">@apps.Count(a => a.Status == "Pending") đơn chờ duyệt</span>
    </div>
    <div class="table-wrapper">
        <table class="table table-borderless align-middle admin-table">
            <thead>
                <tr>
                    <th>Giảng viên</th>
                    <th>Khóa học đăng ký</th>
                    <th>Ngày đăng ký</th>
                    <th>Trạng thái</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var app in apps)
            {
                <tr>
                    <td class="fw-semibold">@app.User?.FullName</td>
                    <td>@app.Course?.CourseName</td>
                    <td class="muted">@app.ApplyDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <span class="pill @(app.Status == "Pending" ? "warning" : (app.Status == "Approved" ? "success" : "danger"))">
                            @app.Status
                        </span>
                    </td>
                    <td>
                        @if (app.Status == "Pending")
                        {
                            <div class="d-flex gap-2">
                                <form asp-action="HandleApplication" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@app.Id" />
                                    <input type="hidden" name="action" value="Approve" />
                                    <button class="btn btn-sm" style="background: #dcfce7; color: #15803d; border: 1px solid #bbf7d0;">Duyệt</button>
                                </form>
                                <form asp-action="HandleApplication" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@app.Id" />
                                    <input type="hidden" name="action" value="Reject" />
                                    <button class="btn btn-sm" style="background: #fee2e2; color: #b91c1c; border: 1px solid #fecdd3;">Từ chối</button>
                                </form>
                            </div>
                        }
                        else
                        {
                            <span class="muted">—</span>
                        }
                    </td>
                </tr>
            }
            @if (!apps.Any())
            {
                <tr>
                    <td colspan="5" class="text-center muted">Chưa có đơn đăng ký nào.</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<div class="panel-card" style="margin-top: 24px;">
    <div class="panel-head">
        <h4>Gán giảng viên vào khóa học (Thủ công)</h4>
    </div>
    <form asp-action="AssignInstructorToCourse" method="post" class="row g-3">
        @Html.AntiForgeryToken()
        <div class="col-md-6">
            <label class="form-label">Giảng viên</label>
            <select name="instructorId" class="form-select">
                @foreach (var ins in Model.Instructors)
                {
                    <option value="@ins.User.Id">@ins.User.FullName (@ins.User.Username)</option>
                }
            </select>
        </div>
        <div class="col-md-6">
            <label class="form-label">Khóa học</label>
            <select name="courseId" class="form-select">
                @foreach (var c in Model.Courses)
                {
                    <option value="@c.Id">@c.CourseName</option>
                }
            </select>
        </div>
        <div class="col-12">
            <button class="btn solid" type="submit">Gán thủ công</button>
        </div>
    </form>
</div>
