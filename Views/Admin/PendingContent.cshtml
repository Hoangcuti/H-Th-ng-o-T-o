@{
    ViewData["Title"] = "Phê duyệt Nội dung & Giảng viên";
    var pendingLessons = ViewBag.PendingLessons as List<COTHUYPRO.Models.Lesson> ?? new();
    var pendingExams = ViewBag.PendingExams as List<COTHUYPRO.Models.Exam> ?? new();
    var pendingAssignments = ViewBag.PendingAssignments as List<COTHUYPRO.Models.Assignment> ?? new();
    var pendingApps = ViewBag.PendingApplications as List<COTHUYPRO.Models.InstructorCourseApplication> ?? new();
    var examQuestionHtml = ViewBag.ExamQuestionHtml as Dictionary<int, string> ?? new();
}

<div class="container-fluid p-4 page-shell">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <p class="text-muted small mb-1">Admin / Phê duyệt</p>
            <h2 class="fw-bold mb-0 text-dark">Trung tâm Phê duyệt</h2>
        </div>
        <a asp-action="ContentHistory" class="btn btn-outline-secondary rounded-pill px-4 bg-white shadow-sm fw-bold">
            <i class="bi bi-clock-history me-1"></i> Lịch sử thao tác
        </a>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm border-0 mb-4">
            <div class="d-flex align-items-center">
                <i class="bi bi-check-circle-fill me-3 fs-4"></i>
                <div>@TempData["Message"]</div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Lessons -->
    <div class="card soft-card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
        <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-journal-text text-primary fs-5"></i>
                <h5 class="m-0 fw-bold">Bài giảng chờ phê duyệt</h5>
            </div>
            <span class="badge bg-primary rounded-pill px-3">@pendingLessons.Count</span>
        </div>
        <div class="card-body p-0">
            @if (!pendingLessons.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-check2-all display-6 d-block mb-2 opacity-25"></i>
                    <p class="m-0 small fw-medium">Tất cả bài giảng đã xử lý</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light small text-muted text-uppercase fw-bold">
                            <tr>
                                <th class="ps-4">Tên bài giảng</th>
                                <th>Khóa học</th>
                                <th>Người tạo</th>
                                <th class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var l in pendingLessons)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-dark">@l.Title</td>
                                    <td class="text-muted small">@(l.Course?.CourseName ?? "—")</td>
                                    <td>
                                        @if (l.CreatedByUser != null)
                                        {
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="avatar-sm bg-info-subtle text-info rounded-circle d-flex align-items-center justify-content-center" style="width:24px; height:24px; font-size:10px;">@l.CreatedByUser.FullName.Substring(0,1)</div>
                                                <span class="small fw-medium">@l.CreatedByUser.FullName</span>
                                            </div>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex gap-1 justify-content-center">
                                            <button class="btn btn-sm btn-outline-secondary rounded-pill px-3"
                                                    data-bs-toggle="modal" data-bs-target="#lessonDetailModal"
                                                    data-type="Bài giảng"
                                                    data-lesson-id="@l.Id"
                                                    data-title="@l.Title"
                                                    data-course="@((l.Course?.CourseName) ?? "N/A")"
                                                    data-author="@((l.CreatedByUser?.FullName) ?? "N/A")"
                                                    data-created="@l.CreatedAt.ToString("dd/MM/yyyy HH:mm")"
                                                    data-order="@l.OrderIndex"
                                                    data-duration="@l.Duration"
                                                    data-video="@System.Net.WebUtility.HtmlEncode(l.VideoUrl ?? "")"
                                                    data-doc="@System.Net.WebUtility.HtmlEncode(l.DocumentUrl ?? "")"
                                                    data-content="@System.Net.WebUtility.HtmlEncode(l.Content ?? "")"
                                                    data-published="@l.IsPublished.ToString().ToLower()">
                                                <i class="bi bi-eye me-1"></i>Chi tiết
                                            </button>
                                            <button class="btn btn-sm btn-success rounded-pill px-3 fw-bold shadow-sm" onclick="approveLesson(@l.Id)">Duyệt</button>
                                            <button class="btn btn-sm btn-outline-danger border-0 rounded-pill px-3 fw-bold" onclick="rejectLesson(@l.Id)">Từ chối</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Quiz & Assignments -->
    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card soft-card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
                <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center justify-content-between">
                    <h6 class="m-0 fw-bold"><i class="bi bi-patch-question me-2 text-warning"></i>Quiz chờ duyệt</h6>
                    <span class="badge bg-warning text-dark rounded-pill">@pendingExams.Count</span>
                </div>
                <div class="card-body p-0">
                    @if (!pendingExams.Any())
                    {
                        <p class="text-center py-4 text-muted small">Trống</p>
                    }
                    else
                    {
                        @foreach (var e in pendingExams)
                        {
                            <div class="px-4 py-3 border-bottom d-flex justify-content-between align-items-center hover-bg-light">
                                <div>
                                    <div class="fw-bold small text-dark">@e.Title</div>
                                    <div class="text-muted" style="font-size: 11px;">@e.Course?.CourseName</div>
                                </div>
                                <div class="d-flex gap-1">
                                    @{
                                        var extra = $"Pass: {e.PassingScore}/10 | Thời gian: {e.DurationMinutes} phút";
                                        var qHtmlEncoded = examQuestionHtml.TryGetValue(e.Id, out var htmlStr)
                                            ? System.Net.WebUtility.HtmlEncode(htmlStr)
                                            : "";
                                    }
                                    <button class="btn btn-sm btn-outline-secondary rounded-pill px-2" data-bs-toggle="modal" data-bs-target="#detailModal"
                                            data-type="Quiz"
                                            data-title="@e.Title"
                                            data-course="@((e.Course?.CourseName) ?? "N/A")"
                                            data-author="@((e.CreatedByUser?.FullName) ?? "N/A")"
                                            data-created="@e.CreatedAt.ToString("dd/MM/yyyy HH:mm")"
                                            data-extra="@extra"
                                            data-questions="@qHtmlEncoded">
                                        <i class="bi bi-info-circle"></i>
                                    </button>
                                    <button class="btn btn-sm btn-success p-1 rounded-circle" onclick="approveExam(@e.Id)" title="Duyệt"><i class="bi bi-check"></i></button>
                                    <button class="btn btn-sm btn-outline-danger p-1 rounded-circle border-0" onclick="rejectExam(@e.Id)" title="Từ chối"><i class="bi bi-x"></i></button>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card soft-card border-0 shadow-sm rounded-4 h-100 overflow-hidden">
                <div class="card-header bg-white border-bottom py-3 px-4 d-flex align-items-center justify-content-between">
                    <h6 class="m-0 fw-bold"><i class="bi bi-file-earmark-arrow-up me-2 text-info"></i>Bài tập chờ duyệt</h6>
                    <span class="badge bg-info rounded-pill">@pendingAssignments.Count</span>
                </div>
                <div class="card-body p-0">
                    @if (!pendingAssignments.Any())
                    {
                        <p class="text-center py-4 text-muted small">Trống</p>
                    }
                    else
                    {
                        @foreach (var a in pendingAssignments)
                        {
                            <div class="px-4 py-3 border-bottom d-flex justify-content-between align-items-center hover-bg-light">
                                <div>
                                    <div class="fw-bold small text-dark">@a.Title</div>
                                    <div class="text-muted" style="font-size: 11px;">@a.Course?.CourseName</div>
                                </div>
                                <div class="d-flex gap-1">
                                    <button class="btn btn-sm btn-outline-secondary rounded-pill px-2" data-bs-toggle="modal" data-bs-target="#detailModal"
                                            data-type="Bài tập"
                                            data-title="@a.Title"
                                            data-course="@((a.Course?.CourseName) ?? "N/A")"
                                            data-author="@((a.CreatedByUser?.FullName) ?? "N/A")"
                                            data-created="@a.CreatedAt.ToString("dd/MM/yyyy HH:mm")"
                                            data-extra="@($"Điểm tối đa: {a.MaxScore} | Deadline: {(a.DueDate?.ToString("dd/MM/yyyy HH:mm") ?? "-")}")">
                                        <i class="bi bi-info-circle"></i>
                                    </button>
                                    <button class="btn btn-sm btn-success p-1 rounded-circle" onclick="approveAssignment(@a.Id)" title="Duyệt"><i class="bi bi-check"></i></button>
                                    <button class="btn btn-sm btn-outline-danger p-1 rounded-circle border-0" onclick="rejectAssignment(@a.Id)" title="Từ chối"><i class="bi bi-x"></i></button>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Lesson Full Detail Modal -->
<div class="modal fade" id="lessonDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg" style="border-radius:18px; overflow:hidden;">
            <!-- Header -->
            <div class="modal-header border-0 px-4 py-3" style="background:linear-gradient(135deg,#6366f1,#8b5cf6)">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:42px;height:42px;background:rgba(255,255,255,.2)">
                        <i class="bi bi-journal-text text-white fs-5"></i>
                    </div>
                    <div>
                        <div class="text-white-50 small">Xem chi tiết · Bài giảng chờ duyệt</div>
                        <h5 class="modal-title fw-bold mb-0 text-white" id="ldTitle">—</h5>
                    </div>
                </div>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <!-- Body -->
            <div class="modal-body p-0">
                <div class="row g-0">
                    <!-- Left: info + video -->
                    <div class="col-lg-6 border-end p-4" style="background:#fafbff">
                        <!-- Meta info -->
                        <div class="mb-4">
                            <h6 class="text-muted text-uppercase small mb-3" style="letter-spacing:.08em"><i class="bi bi-info-circle me-1"></i>Thông tin chung</h6>
                            <div class="d-grid gap-2">
                                <div class="p-3 rounded-3" style="background:#fff;border:1px solid #e5e7eb">
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted small">Tiêu đề</span>
                                        <span class="fw-semibold text-dark" id="ldTitleInfo">—</span>
                                    </div>
                                </div>
                                <div class="p-3 rounded-3" style="background:#fff;border:1px solid #e5e7eb">
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted small">Khóa học</span>
                                        <span class="fw-semibold text-primary" id="ldCourse">—</span>
                                    </div>
                                </div>
                                <div class="p-3 rounded-3" style="background:#fff;border:1px solid #e5e7eb">
                                    <div class="d-flex justify-content-between gap-3">
                                        <span class="text-muted small">Thứ tự bài</span>
                                        <span class="fw-semibold" id="ldOrder">—</span>
                                    </div>
                                </div>
                                <div class="p-3 rounded-3" style="background:#fff;border:1px solid #e5e7eb">
                                    <div class="d-flex justify-content-between gap-3">
                                        <span class="text-muted small">Thời lượng (phút)</span>
                                        <span class="fw-semibold" id="ldDuration">—</span>
                                    </div>
                                </div>
                                <div class="p-3 rounded-3" style="background:#fff;border:1px solid #e5e7eb">
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted small">Người tạo</span>
                                        <span class="fw-semibold" id="ldAuthor">—</span>
                                    </div>
                                </div>
                                <div class="p-3 rounded-3" style="background:#fff;border:1px solid #e5e7eb">
                                    <div class="d-flex justify-content-between">
                                        <span class="text-muted small">Ngày tạo</span>
                                        <span class="fw-semibold" id="ldCreated">—</span>
                                    </div>
                                </div>
                                <div class="p-3 rounded-3" style="background:#fff;border:1px solid #e5e7eb">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="text-muted small">Trạng thái xuất bản</span>
                                        <span id="ldPublished">—</span>
                                    </div>
                                </div>
                                <div class="p-3 rounded-3 d-none" id="ldDocWrap" style="background:#fff;border:1px solid #e5e7eb">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="text-muted small">Tài liệu đính kèm</span>
                                        <a id="ldDoc" href="#" target="_blank" class="small text-primary fw-semibold"><i class="bi bi-file-earmark-arrow-down me-1"></i>Xem file</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Video preview -->
                        <div id="ldVideoSection" class="d-none">
                            <h6 class="text-muted text-uppercase small mb-3" style="letter-spacing:.08em"><i class="bi bi-play-circle me-1"></i>Video bài giảng</h6>
                            <div class="ratio ratio-16x9 rounded-3 overflow-hidden shadow-sm">
                                <iframe id="ldVideoFrame" src="" frameborder="0" allowfullscreen allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"></iframe>
                            </div>
                            <div class="mt-2">
                                <a id="ldVideoLink" href="#" target="_blank" class="small text-muted"><i class="bi bi-link-45deg me-1"></i><span id="ldVideoLinkText"></span></a>
                            </div>
                        </div>
                        <div id="ldNoVideo" class="text-center py-4 text-muted">
                            <i class="bi bi-camera-video-off display-6 opacity-25 d-block mb-2"></i>
                            <span class="small">Không có video</span>
                        </div>
                    </div>
                    <!-- Right: content -->
                    <div class="col-lg-6 p-4" style="background:#fff">
                        <h6 class="text-muted text-uppercase small mb-3" style="letter-spacing:.08em"><i class="bi bi-file-text me-1"></i>Nội dung bài giảng</h6>
                        <div id="ldContent" class="lesson-content-preview border rounded-3 p-3" style="min-height:420px;max-height:600px;overflow-y:auto;font-size:0.93rem;line-height:1.7">—</div>
                    </div>
                </div>
            </div>
            <!-- Footer: Đóng + Duyệt + Từ chối (no save) -->
            <div class="modal-footer border-0 px-4 py-3" style="background:#f9fafb">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
                <div class="ms-auto d-flex gap-2">
                    <button type="button" class="btn btn-outline-danger rounded-pill px-4 fw-bold" id="ldRejectBtn">Từ chối</button>
                    <button type="button" class="btn btn-success rounded-pill px-4 fw-bold shadow-sm" id="ldApproveBtn">
                        <i class="bi bi-check2-circle me-1"></i>Duyệt
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Keep old generic modal for Quiz/Assignment -->
<div class="modal fade" id="detailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header">
                <div>
                    <div class="text-muted small" id="detailType">Chi tiết</div>
                    <h5 class="modal-title fw-bold mb-0" id="detailTitle">—</h5>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <dl class="row mb-0">
                    <dt class="col-4 text-muted small">Khóa học</dt>
                    <dd class="col-8 fw-semibold" id="detailCourse">—</dd>
                    <dt class="col-4 text-muted small">Người tạo</dt>
                    <dd class="col-8" id="detailAuthor">—</dd>
                    <dt class="col-4 text-muted small">Ngày tạo</dt>
                    <dd class="col-8" id="detailCreated">—</dd>
                    <dt class="col-4 text-muted small">Thông tin</dt>
                    <dd class="col-8 text-muted" id="detailExtra">—</dd>
                    <dt class="col-4 text-muted small d-none" id="questionsLabel">Câu hỏi</dt>
                    <dd class="col-8 text-muted d-none" id="detailQuestions"></dd>
                </dl>
            </div>
        </div>
    </div>
</div>

<style>
    .page-shell { background: linear-gradient(180deg, #f7f9fb 0%, #f2f5fa 100%); }
    .soft-card { background: #fff; }
    .hover-bg-light:hover { background-color: #f8fafc; }
    .avatar-sm { font-weight: 700; }
    /* Lesson content preview styles */
    .lesson-content-preview h1, .lesson-content-preview h2 { font-size: 1.1rem; font-weight: 700; margin-top: 1rem; }
    .lesson-content-preview h3, .lesson-content-preview h4 { font-size: 0.97rem; font-weight: 600; }
    .lesson-content-preview p { margin-bottom: .6rem; }
    .lesson-content-preview ul, .lesson-content-preview ol { padding-left: 1.4rem; }
    .lesson-content-preview code { background: #f3f4f6; padding: 2px 6px; border-radius: 4px; font-size: .85em; }
    .lesson-content-preview pre { background: #1e1e2e; color: #cdd6f4; border-radius: 8px; padding: 1rem; font-size: .82rem; overflow-x:auto; }
    #lessonDetailModal .modal-header { min-height: 72px; }
</style>

@section Scripts {
    <script>
        async function post(url) {
            const res = await fetch(url, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } });
            if (res.ok) location.reload();
            else alert('Thao tác thất bại. Vui lòng thử lại.');
        }
        const approveLesson = (id) => { if (confirm('Phê duyệt bài giảng này?')) post(`/Admin/ApproveLesson/${id}`); };
        const rejectLesson = (id) => { if (confirm('Từ chối bài giảng này?')) post(`/Admin/RejectLesson/${id}`); };
        const approveExam = (id) => { if (confirm('Phê duyệt quiz này?')) post(`/Admin/ApproveExam/${id}`); };
        const rejectExam = (id) => { if (confirm('Từ chối quiz này?')) post(`/Admin/RejectExam/${id}`); };
        const approveAssignment = (id) => { if (confirm('Phê duyệt bài tập này?')) post(`/Admin/ApproveAssignment/${id}`); };
        const rejectAssignment = (id) => { if (confirm('Từ chối bài tập này?')) post(`/Admin/RejectAssignment/${id}`); };

        // ===== Lesson Full Detail Modal =====
        const lessonDetailModal = document.getElementById('lessonDetailModal');
        const decodeHtml = (str) => str
            .replace(/&lt;/g,'<').replace(/&gt;/g,'>')
            .replace(/&quot;/g,'"').replace(/&amp;/g,'&').replace(/&#39;/g,"'");

        const getYouTubeEmbed = (url) => {
            if (!url) return null;
            const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?(?:.*&)?v=|embed\/|v\/))([\w-]{11})/);
            return match ? `https://www.youtube.com/embed/${match[1]}` : null;
        };

        lessonDetailModal?.addEventListener('show.bs.modal', event => {
            const btn = event.relatedTarget;
            if (!btn) return;
            const lessonId  = btn.dataset.lessonId || '';
            const title     = btn.dataset.title || '—';
            const course    = btn.dataset.course || '—';
            const author    = btn.dataset.author || '—';
            const created   = btn.dataset.created || '—';
            const order     = btn.dataset.order || '—';
            const duration  = btn.dataset.duration || '0';
            const videoRaw  = decodeHtml(btn.dataset.video || '');
            const docRaw    = decodeHtml(btn.dataset.doc || '');
            const contentRaw= decodeHtml(btn.dataset.content || '');
            const published = btn.dataset.published === 'true';

            lessonDetailModal.querySelector('#ldTitle').textContent = title;
            lessonDetailModal.querySelector('#ldTitleInfo').textContent = title;
            lessonDetailModal.querySelector('#ldCourse').textContent = course;
            lessonDetailModal.querySelector('#ldOrder').textContent = order;
            lessonDetailModal.querySelector('#ldDuration').textContent = duration + ' phút';
            lessonDetailModal.querySelector('#ldAuthor').textContent = author;
            lessonDetailModal.querySelector('#ldCreated').textContent = created;
            lessonDetailModal.querySelector('#ldPublished').innerHTML = published
                ? '<span class="badge bg-success-subtle text-success rounded-pill px-3"><i class="bi bi-eye me-1"></i>Hiển thị</span>'
                : '<span class="badge bg-secondary-subtle text-muted rounded-pill px-3"><i class="bi bi-eye-slash me-1"></i>Ẩn</span>';

            // Document
            const docWrap = lessonDetailModal.querySelector('#ldDocWrap');
            const docLink = lessonDetailModal.querySelector('#ldDoc');
            if (docRaw) {
                docWrap.classList.remove('d-none');
                docLink.href = docRaw;
            } else {
                docWrap.classList.add('d-none');
            }

            // Video
            const videoSection = lessonDetailModal.querySelector('#ldVideoSection');
            const noVideo = lessonDetailModal.querySelector('#ldNoVideo');
            const frame = lessonDetailModal.querySelector('#ldVideoFrame');
            const vidLink = lessonDetailModal.querySelector('#ldVideoLink');
            const vidLinkText = lessonDetailModal.querySelector('#ldVideoLinkText');
            const embedUrl = getYouTubeEmbed(videoRaw);
            if (videoRaw) {
                videoSection.classList.remove('d-none');
                noVideo.classList.add('d-none');
                frame.src = embedUrl || videoRaw;
                vidLink.href = videoRaw;
                vidLinkText.textContent = videoRaw.length > 60 ? videoRaw.substring(0, 60) + '...' : videoRaw;
            } else {
                videoSection.classList.add('d-none');
                noVideo.classList.remove('d-none');
                frame.src = '';
            }

            // Content
            const contentEl = lessonDetailModal.querySelector('#ldContent');
            if (contentRaw.trim()) {
                contentEl.innerHTML = contentRaw;
            } else {
                contentEl.innerHTML = '<p class="text-muted fst-italic">Không có nội dung văn bản.</p>';
            }

            // Approve / Reject buttons
            lessonDetailModal.querySelector('#ldApproveBtn').onclick = () => {
                bootstrap.Modal.getInstance(lessonDetailModal).hide();
                approveLesson(lessonId);
            };
            lessonDetailModal.querySelector('#ldRejectBtn').onclick = () => {
                bootstrap.Modal.getInstance(lessonDetailModal).hide();
                rejectLesson(lessonId);
            };
        });
        // Clean up iframe when modal closes
        lessonDetailModal?.addEventListener('hidden.bs.modal', () => {
            const f = lessonDetailModal.querySelector('#ldVideoFrame');
            if (f) f.src = '';
        });

        // ===== Generic modal for Quiz / Assignment =====
        const detailModal = document.getElementById('detailModal');
        detailModal?.addEventListener('show.bs.modal', event => {
            const button = event.relatedTarget;
            if (!button) return;
            const type = button.getAttribute('data-type') || 'Chi tiết';
            const title = button.getAttribute('data-title') || '—';
            const course = button.getAttribute('data-course') || '—';
            const author = button.getAttribute('data-author') || '—';
            const created = button.getAttribute('data-created') || '—';
            const extra = button.getAttribute('data-extra') || '—';
            const questions = button.getAttribute('data-questions') || '';

            detailModal.querySelector('#detailType').textContent = type;
            detailModal.querySelector('#detailTitle').textContent = title;
            detailModal.querySelector('#detailCourse').textContent = course;
            detailModal.querySelector('#detailAuthor').textContent = author;
            detailModal.querySelector('#detailCreated').textContent = created;
            const extraEl = detailModal.querySelector('#detailExtra');
            if (type === 'Quiz') {
                extraEl.innerHTML = extra;
            } else {
                extraEl.textContent = extra;
            }
            const qsLabel = detailModal.querySelector('#questionsLabel');
            const qsBody = detailModal.querySelector('#detailQuestions');
            if (questions) {
                qsLabel.classList.remove('d-none');
                qsBody.classList.remove('d-none');
                qsBody.innerHTML = decodeHtml(questions);
            } else {
                qsLabel.classList.add('d-none');
                qsBody.classList.add('d-none');
                qsBody.innerHTML = '';
            }
        });
    </script>
    @Html.AntiForgeryToken()
}
