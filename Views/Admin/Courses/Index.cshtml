@model COTHUYPRO.Models.CoursesPageVm
@{
    ViewData["Title"] = "Quản lý khóa học";
}

<div class="page-header">
    <div>
        <p class="eyebrow">Khóa học</p>
        <h2>Quản lý khóa học</h2>
        <p class="muted">Dữ liệu thật từ bảng Courses (Category, Level, Instructors, Classes).</p>
    </div>
    <div class="quick-actions">
        <a class="btn solid" asp-action="CreateCourse">+ Thêm khóa học</a>
    </div>
</div>

<div class="panel-card">
    <div class="panel-head">
        <h4>Danh sách khóa</h4>
        <span class="pill muted">@Model.Courses.Count mục</span>
    </div>
    <div class="table-wrapper">
        <table class="table table-borderless align-middle admin-table">
            <thead>
                <tr>
                    <th>Tên khóa</th>
                    <th>Danh mục</th>
                    <th>Cấp độ</th>
                    <th>Giảng viên</th>
                    <th>Lớp</th>
                    <th>Học viên</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var c in Model.Courses)
            {
                <tr>
                    <td class="fw-semibold">@c.Course.CourseName</td>
                    <td>@c.CategoryName</td>
                    <td>@c.LevelName</td>
                    <td>@string.Join(", ", c.Instructors)</td>
                    <td>@c.ClassCount</td>
                    <td>@c.LearnerCount</td>
                    <td class="d-flex gap-2">
                        <a class="btn ghost btn-sm" asp-action="EditCourse" asp-route-id="@c.Course.Id">✏</a>
                        <form asp-action="DeleteCourse" method="post" onsubmit="return confirm('Xóa khóa học này?');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@c.Course.Id" />
                            <button class="btn btn-sm" style="background:#fee2e2; color:#b91c1c; border:1px solid #fecdd3;">🗑</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
