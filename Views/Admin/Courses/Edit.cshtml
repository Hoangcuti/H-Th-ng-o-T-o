@model COTHUYPRO.Models.CourseFormVm
@{
    ViewData["Title"] = "Chỉnh sửa khóa học";
    var categories = ViewBag.Categories as List<COTHUYPRO.Models.CourseCategory> ?? new();
    var levels = ViewBag.Levels as List<COTHUYPRO.Models.CourseLevel> ?? new();
}

<div class="page-header">
    <div>
        <p class="eyebrow">Khóa học</p>
        <h2>Chỉnh sửa khóa học</h2>
    </div>
</div>

<div class="row g-4 animate-fade-in">
    <div class="col-lg-8">
        <div class="panel-card h-100">
            <div class="panel-head mb-4"><h4>Chỉnh sửa thông tin</h4></div>
            <form asp-action="EditCourse" method="post" class="row g-3">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div class="col-md-12 mb-3">
                    <label class="form-label">Tên khóa học</label>
                    <input asp-for="CourseName" class="form-control" />
                    <span class="text-danger small" asp-validation-for="CourseName"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Danh mục</label>
                    <select asp-for="CategoryId" class="form-select">
                        @foreach (var c in categories) { <option value="@c.Id" selected="@(Model.CategoryId==c.Id)">@c.Name</option> }
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Cấp độ</label>
                    <select asp-for="LevelId" class="form-select">
                        @foreach (var l in levels) { <option value="@l.Id" selected="@(Model.LevelId==l.Id)">@l.Name</option> }
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Giá (VNĐ)</label>
                    <input asp-for="Price" type="number" step="1000" class="form-control" />
                </div>
                <div class="col-md-12 mb-3">
                    <label class="form-label">Link ảnh đại diện</label>
                    <input asp-for="ImageUrl" class="form-control" id="imageUrlInput" />
                </div>
                <div class="col-12 d-flex gap-2 mt-4 pt-4 border-top">
                    <button class="btn solid px-4" type="submit">Lưu thay đổi</button>
                    <a class="btn ghost px-4" asp-action="Courses">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="panel-card h-100">
            <div class="panel-head mb-4"><h4>Xem trước ảnh</h4></div>
            <div id="image-preview" style="width: 100%; aspect-ratio: 16/9; border-radius: 12px; overflow: hidden; background: var(--surface-muted); border: 1px solid var(--border);">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" style="width: 100%; height: 100%; object-fit: cover;" id="previewImg" />
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center h-100 text-muted small">Chưa có ảnh</div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
