@model List<COTHUYPRO.Models.Assignment>
@{
    ViewData["Title"] = "Quản lý Bài tập";
}

<div class="instructor-assignments animate-fade-in">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <p class="text-muted small m-0">Giảng viên / Đánh giá</p>
            <h4 class="fw-bold m-0 text-dark">BÀI TẬP (ASSIGNMENTS)</h4>
        </div>
        <a asp-action="CreateAssignment" class="btn btn-emerald rounded-pill px-4 shadow-sm fw-bold border-0 text-white" style="background: linear-gradient(135deg, #10b981, #059669);">
            <i class="bi bi-plus-lg me-2"></i>Giao bài tập mới
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light small text-muted text-uppercase fw-bold">
                    <tr>
                        <th class="ps-4">Tên bài tập</th>
                        <th>Khóa học</th>
                        <th class="text-center">Hạn nộp</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-file-earmark-arrow-up display-4 d-block mb-3 opacity-25"></i>
                                Chưa có bài tập nào được giao.
                            </td>
                        </tr>
                    }
                    @foreach (var a in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">@a.Title</div>
                                <div class="text-muted small">@a.MaxScore điểm</div>
                            </td>
                            <td class="small fw-medium">@a.Course?.CourseName</td>
                            <td class="text-center small">
                                @if (a.DueDate.HasValue)
                                {
                                    <div class="@(a.DueDate < DateTime.Now ? "text-danger fw-bold" : "")">
                                        @a.DueDate.Value.ToString("dd/MM/yyyy")
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">Không hạn</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (a.Status == "Approved")
                                {
                                    <span class="badge bg-success-subtle text-success rounded-pill px-3 border border-success">Đang mở</span>
                                }
                                else if (a.Status == "Pending")
                                {
                                    <span class="badge bg-warning-subtle text-warning rounded-pill px-3 border border-warning">Chờ duyệt</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-muted rounded-pill px-3 border">Bản nháp</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <a class="btn btn-sm btn-outline-primary rounded-pill px-3 me-2" href="#">
                                        <i class="bi bi-person-check me-1"></i> Chấm điểm
                                    </a>
                                    <a class="btn btn-sm btn-light rounded-pill px-2" href="#">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .bg-success-subtle { background-color: rgba(16, 185, 129, 0.1); }
    .bg-warning-subtle { background-color: rgba(245, 158, 11, 0.1); }
</style>
