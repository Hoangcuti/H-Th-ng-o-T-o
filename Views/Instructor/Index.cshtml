@model COTHUYPRO.Models.InstructorDashboardVm
@{
    ViewData["Title"] = "Bảng điều khiển Giảng viên";
    var years = ViewBag.AcademicYears as IEnumerable<COTHUYPRO.Models.AcademicYear>;
    var semesters = ViewBag.Semesters as IEnumerable<COTHUYPRO.Models.Semester>;
    var blocks = ViewBag.Blocks as IEnumerable<COTHUYPRO.Models.Block>;
}

<!-- FILTER ROW -->
<div class="card border-0 shadow-sm rounded-4 p-4 bg-dark text-white mb-4">
    <form method="get" class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label small fw-bold opacity-75">Năm học</label>
            <select name="yearId" class="form-select bg-secondary border-0 text-white" onchange="this.form.submit()">
                <option value="">-- Tất cả năm --</option>
                @foreach (var y in years ?? Enumerable.Empty<COTHUYPRO.Models.AcademicYear>())
                {
                    <option value="@y.Id" selected="@(ViewBag.SelectedYear == y.Id ? "selected" : null)">Năm @y.YearNumber</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-bold opacity-75">Kỳ học</label>
            <select name="semesterId" class="form-select bg-secondary border-0 text-white" onchange="this.form.submit()">
                <option value="">-- Tất cả kỳ --</option>
                @foreach (var s in semesters ?? Enumerable.Empty<COTHUYPRO.Models.Semester>())
                {
                    <option value="@s.Id" selected="@(ViewBag.SelectedSemester == s.Id ? "selected" : null)">Kỳ @s.SemesterName (@s.Year?.YearNumber)</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-bold opacity-75">Block</label>
            <select name="blockId" class="form-select bg-secondary border-0 text-white" onchange="this.form.submit()">
                <option value="">-- Tất cả Block --</option>
                @foreach (var b in blocks ?? Enumerable.Empty<COTHUYPRO.Models.Block>())
                {
                    <option value="@b.Id" selected="@(ViewBag.SelectedBlock == b.Id ? "selected" : null)">Block @b.BlockName (@b.Semester?.SemesterName)</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <a asp-action="Index" class="btn btn-outline-light w-100 rounded-pill">
                <i class="bi bi-arrow-counterclockwise me-2"></i>Đặt lại
            </a>
        </div>
    </form>
</div>

<!-- STATS ROW -->
<div class="row g-4 mb-4 animate-fade-in">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 p-4 bg-white h-100 position-relative overflow-hidden">
            <div class="position-absolute opacity-10 end-0 bottom-0 mb-n3 me-n3" style="font-size: 5rem;">
                <i class="bi bi-book-half"></i>
            </div>
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                    <i class="bi bi-journal-bookmark-fill fs-4"></i>
                </div>
                <h6 class="m-0 text-muted fw-bold">Khóa đang phụ trách</h6>
            </div>
            <h2 class="display-5 fw-800 m-0 text-dark">@Model.Courses.Count</h2>
            <div class="mt-2 small text-success">
                <i class="bi bi-arrow-up-short"></i> Đang giảng dạy trực tiếp
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 p-4 bg-white h-100 position-relative overflow-hidden">
            <div class="position-absolute opacity-10 end-0 bottom-0 mb-n3 me-n3" style="font-size: 5rem;">
                <i class="bi bi-people"></i>
            </div>
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="bg-success-subtle text-success rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                    <i class="bi bi-person-video3 fs-4"></i>
                </div>
                <h6 class="m-0 text-muted fw-bold">Lớp đang dạy</h6>
            </div>
            <h2 class="display-5 fw-800 m-0 text-dark">@Model.Classes.Count</h2>
            <div class="mt-2 small text-muted">
                Dựa trên bộ lọc hiện tại
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 p-4 bg-white h-100 position-relative overflow-hidden" style="background: linear-gradient(135deg, #0ea5e9, #10b981);">
            <div class="position-absolute opacity-20 end-0 bottom-0 mb-n3 me-n3 text-white" style="font-size: 5rem;">
                <i class="bi bi-mortarboard"></i>
            </div>
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="bg-white bg-opacity-20 text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                    <i class="bi bi-people-fill fs-4"></i>
                </div>
                <h6 class="m-0 text-white fw-bold opacity-75">Tổng học viên</h6>
            </div>
            <h2 class="display-5 fw-800 m-0 text-white">@Model.Students.Count</h2>
            <div class="mt-2 small text-white opacity-75">
                Số lượng học viên trong lớp
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- KHÓA HỌC PHỤ TRÁCH -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 bg-white mb-4">
            <div class="card-header bg-white border-0 py-4 px-4 d-flex justify-content-between align-items-center">
                <h5 class="m-0 fw-bold text-dark"><i class="bi bi-collection-play me-2 text-primary"></i>Danh sách môn được giao</h5>
            </div>
            <div class="card-body px-4 pb-4">
                @if (!Model.Courses.Any())
                {
                    <div class="text-center py-5">
                        <img src="~/images/empty.svg" alt="Empty" style="width: 120px; opacity: 0.5;" />
                        <p class="text-muted mt-3 italic">Bạn chưa được phân công quản lý khóa học nào.</p>
                    </div>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var c in Model.Courses)
                        {
                            <div class="col-md-6">
                                <div class="course-mini-card p-3 rounded-4 border hover-shadow-sm transition-all" style="background: #f8fafc;">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <span class="badge bg-primary-subtle text-primary rounded-pill px-2" style="font-size: 0.65rem;">@c.Category?.Name</span>
                                        <span class="text-muted style-italic small">@c.Level?.Name</span>
                                    </div>
                                    <h6 class="fw-bold text-dark mb-3">@c.CourseName</h6>
                                    <div class="d-flex gap-2">
                                        <a asp-action="CourseLessons" asp-route-courseId="@c.Id" class="btn btn-sm btn-white border w-100 rounded-3 shadow-sm py-2">
                                            <i class="bi bi-gear-fill me-1"></i> Quản lý nội dung
                                        </a>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <!-- LỊCH LỚP HỌC -->
        <div class="card border-0 shadow-sm rounded-4 bg-white">
            <div class="card-header bg-white border-0 py-4 px-4">
                <h5 class="m-0 fw-bold text-dark"><i class="bi bi-calendar-event me-2 text-success"></i>Lớp học chi tiết (Mã lớp)</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 text-center">
                        <thead class="bg-light small text-muted text-uppercase">
                            <tr>
                                <th class="ps-4 text-start">Mã lớp</th>
                                <th>Môn học</th>
                                <th>Block</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                    <tbody>
                    @foreach (var cls in Model.Classes)
                    {
                        <tr>
                            <td class="ps-4 text-start">
                                <span class="fw-bold text-primary">@cls.ClassCode</span>
                            </td>
                            <td>@cls.Course?.CourseName</td>
                            <td>
                                <span class="badge bg-info-subtle text-info rounded-pill px-3">
                                    @(cls.Block?.BlockName ?? "N/A")
                                </span>
                            </td>
                            <td>
                                <a asp-action="StudentList" asp-route-classId="@cls.Id" class="btn btn-sm btn-outline-dark rounded-pill px-3">
                                    <i class="bi bi-people-fill me-1"></i> Xem DS sinh viên
                                </a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
          </div>
        </div>
    </div>

    <!-- SIDE PANEL -->
    <div class="col-lg-4">
        <!-- PHÍM TẮT QUẢN LÝ -->
        <div class="card border-0 shadow-sm rounded-4 bg-white mb-4 overflow-hidden">
            <div class="card-header bg-white border-0 py-4 px-4 pb-0">
                <h5 class="m-0 fw-bold text-dark"><i class="bi bi-grid-fill me-2 text-primary"></i>Phím tắt nhanh</h5>
            </div>
            <div class="card-body p-4">
                <div class="row g-2">
                    <div class="col-6">
                        <a asp-action="Exams" class="btn btn-outline-primary border-0 rounded-4 p-3 w-100 h-100 d-flex flex-column align-items-center gap-2 bg-light bg-opacity-50 hover-bg-primary-subtle transition-all">
                            <i class="bi bi-patch-question fs-3"></i>
                            <span class="small fw-bold">QUẢN LÝ QUIZ</span>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-action="Assignments" class="btn btn-outline-success border-0 rounded-4 p-3 w-100 h-100 d-flex flex-column align-items-center gap-2 bg-light bg-opacity-50 hover-bg-success-subtle transition-all">
                            <i class="bi bi-file-earmark-arrow-up fs-3"></i>
                            <span class="small fw-bold">BÀI TẬP</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- DANH SÁCH HỌC VIÊN -->
        <div class="card border-0 shadow-sm rounded-4 bg-white">
            <div class="card-header bg-white border-0 py-4 px-4 d-flex justify-content-between align-items-center">
                <h5 class="m-0 fw-bold text-dark">Học viên của tôi gần đây</h5>
            </div>
            <div class="card-body p-0 px-3 pb-3">
                <div class="d-flex flex-column gap-2">
                    @foreach (var st in Model.Students.Take(8))
                    {
                        <div class="d-flex align-items-center gap-3 p-2 rounded-3 hover-bg-light transition-all">
                            <div class="avatar-sm rounded-circle bg-primary-subtle text-primary fw-bold d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; flex-shrink: 0;">
                                @st.FullName.Substring(0, 1).ToUpper()
                            </div>
                            <div class="overflow-hidden">
                                <div class="fw-bold text-dark text-truncate">@st.FullName</div>
                                <div class="text-muted small text-truncate">@st.Email</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-shadow-sm:hover { box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); transform: translateY(-2px); }
    .transition-all { transition: all 0.3s ease; }
    .bg-primary-subtle { background-color: rgba(14, 165, 233, 0.1) !important; }
    .bg-success-subtle { background-color: rgba(16, 185, 129, 0.1) !important; }
    .bg-info-subtle { background-color: rgba(6, 182, 212, 0.1) !important; }
    .display-5 { font-size: 2.5rem; letter-spacing: -1px; }
    .fw-800 { font-weight: 800; }
    .hover-bg-light:hover { background-color: #f8fafc; }
    .btn-white { background: #fff; color: #1e293b; }
    .btn-white:hover { background: #f1f5f9; }
</style>
