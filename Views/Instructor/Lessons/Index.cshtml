@model COTHUYPRO.Models.CoursesPageVm
@{
    ViewData["Title"] = "Quản lý bài giảng theo khóa học";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <p class="eyebrow">Quản lý nội dung</p>
        <h2 class="m-0">QUẢN LÝ NỘI DUNG CHƯƠNG TRÌNH & LỘ TRÌNH BÀI HỌC</h2>
    </div>
</div>

<div class="panel-card shadow-sm border-0 rounded-4 overflow-hidden">
    <div class="panel-head d-flex justify-content-between align-items-center p-4 bg-white border-bottom">
        <div class="d-flex align-items-center gap-3">
            <h4 class="fw-bold m-0 text-dark">Lựa chọn khóa học</h4>
            <span class="badge bg-primary-soft text-primary rounded-pill px-3">@Model.Courses.Count khóa</span>
        </div>
        <div class="search-container" style="width: 320px;">
            <div class="input-group input-group-merge">
                <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                <input type="text" id="courseSearch" class="form-control bg-light border-0 shadow-none" placeholder="Tìm tên khóa học...">
            </div>
        </div>
    </div>
    
    <div class="table-responsive">
        <table id="courseTable" class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr class="text-uppercase small fw-bold text-muted">
                    <th class="ps-4" style="width: 80px;">ID</th>
                    <th>Khóa học</th>
                    <th>Danh mục</th>
                    <th class="text-center">Số LỘ TRÌNH</th>
                    <th class="text-end pe-4">Thao tác</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var c in Model.Courses)
            {
                <tr>
                    <td class="ps-4 fw-bold text-secondary">#@c.Course.Id</td>
                    <td>
                        <div class="d-flex align-items-center">
                            <div class="course-icon me-3 bg-primary-soft text-primary rounded-3 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                <i class="bi bi-journal-bookmark-fill"></i>
                            </div>
                            <div>
                                <div class="fw-bold text-dark fs-6">@c.Course.CourseName</div>
                                <div class="text-muted small">@c.LevelName</div>
                            </div>
                        </div>
                    </td>
                    <td>
                        <span class="badge bg-light text-dark border rounded-pill px-3">@c.CategoryName</span>
                    </td>
                    <td class="text-center">
                        <span class="fw-bold text-primary">@c.ClassCount</span> <small class="text-muted">lớp</small>
                    </td>
                    <td class="text-end pe-4">
                        <div class="d-flex gap-2 justify-content-end">
                            <a class="btn btn-sm btn-outline-primary rounded-pill px-3" asp-action="CourseLessons" asp-route-courseId="@c.Course.Id">
                                <i class="bi bi-list-check me-1"></i> Quản lý bài học
                            </a>
                            <a class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm" asp-action="CreateBulk" asp-route-courseId="@c.Course.Id">
                                <i class="bi bi-plus-lg me-1"></i> Thêm nhanh
                            </a>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            applyLiveSearch('courseSearch', 'courseTable');
        });
    </script>
}

<style>
    .bg-primary-soft { background-color: rgba(13, 110, 253, 0.1); }
    .input-group-merge .form-control { border-radius: 0 12px 12px 0; }
    .input-group-merge .input-group-text { border-radius: 12px 0 0 12px; }
    .table-hover tbody tr:hover { background-color: rgba(0,0,0,0.01); }
</style>
