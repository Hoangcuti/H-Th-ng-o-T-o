@model COTHUYPRO.Models.CourseLessonsVm
@{
    ViewData["Title"] = $"Nội dung: {Model.CourseName}";
}

<!-- HEADER -->
<div class="d-flex justify-content-between align-items-center mb-4 animate-fade-in">
    <div>
        <h4 class="fw-bold m-0 text-dark">Phân mục bài học</h4>
        <p class="text-muted small m-0">Quản lý chương trình giảng dạy và học liệu</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary rounded-pill px-4 shadow-sm bg-white" asp-action="Index" style="border-color: #e2e8f0; color: #64748b;">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
        <a class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold" asp-action="CreateLesson" asp-route-courseId="@Model.CourseId">
            <i class="bi bi-plus-lg me-1"></i> Thêm bài học mới
        </a>
    </div>
</div>

<div class="row animate-fade-in delay-100">
    <div class="col-12">
        @if (!Model.Chapters.Any())
        {
            <div class="card border-0 shadow-sm rounded-4 bg-white py-5 text-center">
                <i class="bi bi-journal-x fs-1 text-muted opacity-20"></i>
                <h5 class="mt-3 text-dark fw-bold">Chưa có nội dung</h5>
                <p class="text-muted">Bắt đầu bằng cách thêm chương mới hoặc bài học lẻ.</p>
                <div class="mt-2">
                    <a class="btn btn-primary rounded-pill px-4" asp-action="CreateLesson" asp-route-courseId="@Model.CourseId">Tạo bài học đầu tiên</a>
                </div>
            </div>
        }
        else
        {
            @foreach (var chapter in Model.Chapters)
            {
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4 bg-white">
                    <div class="card-header p-4 d-flex justify-content-between align-items-center bg-white border-bottom-0">
                        <div class="d-flex align-items-center gap-3">
                            <div class="bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 42px; height: 42px;">
                                <i class="bi bi-folder2-open fs-5"></i>
                            </div>
                            <div>
                                <h5 class="fw-bold m-0 text-dark">@chapter.Title</h5>
                                <span class="text-muted small">@chapter.Lessons.Count bài học trong mục này</span>
                            </div>
                        </div>
                        <div class="dropdown">
                            <button class="btn btn-icon btn-light rounded-circle shadow-none" data-bs-toggle="dropdown">
                                <i class="bi bi-three-dots-vertical"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg rounded-3">
                                <li><a class="dropdown-item py-2" href="#"><i class="bi bi-pencil me-2"></i>Sửa tên chương</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item py-2 text-danger" href="#"><i class="bi bi-trash me-2"></i>Xóa chương</a></li>
                            </ul>
                        </div>
                    </div>
                    
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light small text-muted text-uppercase">
                                <tr>
                                    <th class="ps-4" style="width: 70px;">STT</th>
                                    <th>Tiêu đề bài học</th>
                                    <th class="text-center">Tài liệu</th>
                                    <th class="text-center">Trạng thái</th>
                                    <th class="text-end pe-4">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!chapter.Lessons.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-5 text-muted small italic">
                                            Chưa có bài học nào trong chương này.
                                        </td>
                                    </tr>
                                }
                                @foreach (var l in chapter.Lessons)
                                {
                                    <tr>
                                        <td class="ps-4 text-muted fw-bold">#@l.OrderIndex</td>
                                        <td>
                                            <div class="fw-bold text-dark">@l.Title</div>
                                            @if (!string.IsNullOrEmpty(l.DocumentUrl))
                                            {
                                                <span class="text-muted small d-inline-block text-truncate" style="max-width: 200px;">
                                                    <i class="bi bi-file-earmark-pdf me-1"></i>@l.DocumentUrl.Split('/').Last()
                                                </span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (!string.IsNullOrEmpty(l.DocumentUrl))
                                            {
                                                <span class="badge bg-info-subtle text-info rounded-pill px-3">Có đính kèm</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @{
                                                var (bClass, icon, text) = l.Status switch {
                                                    "Approved" => ("bg-success", "bi-check-circle-fill", "Đã duyệt"),
                                                    "Pending" => ("bg-warning text-dark", "bi-clock-history", "Đợi duyệt"),
                                                    _ => ("bg-secondary", "bi-pencil-square", "Bản nháp")
                                                };
                                            }
                                            <span class="badge @bClass rounded-pill px-3 shadow-sm">
                                                <i class="bi @icon me-1"></i> @text
                                            </span>
                                        </td>
                                        <td class="text-end pe-4">
                                            <div class="d-flex gap-2 justify-content-end">
                                                <a class="btn btn-sm btn-outline-primary rounded-circle p-0 d-flex align-items-center justify-content-center shadow-sm" 
                                                   style="width:34px; height:34px;"
                                                   asp-action="EditLesson" asp-route-id="@l.Id" title="Sửa">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <form asp-action="DeleteLesson" method="post" class="d-inline" onsubmit="return confirm('Xóa bài học này?');">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@l.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle p-0 d-flex align-items-center justify-content-center shadow-sm" 
                                                            style="width:34px; height:34px;" title="Xóa">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    .bg-primary-subtle { background-color: rgba(14, 165, 233, 0.1) !important; }
    .bg-info-subtle { background-color: rgba(6, 182, 212, 0.1) !important; }
    .bg-secondary-subtle { background-color: rgba(100, 116, 139, 0.1) !important; }
    .table thead th { border-top: 0; background-color: #f8fafc; border-bottom: 1px solid #e2e8f0; }
    .table tbody td { padding: 1rem 0.5rem; border-bottom: 1px solid #f1f5f9; }
    .btn-outline-primary:hover { border-color: transparent; }
    .dropdown-item:hover { background-color: #f1f5f9; }
</style>

@section Scripts {
    <script>
        // Placeholder for future status update logic if needed
    </script>
}
