@model IEnumerable<ASM.Models.User>

@{
    ViewData["Title"] = "Manage Users";
}

<div class="container mt-5">
    <h2>Manage Users</h2>

    <table class="table">
        <thead>
            <tr>
                <th>Email</th>
                <th>Full Name</th>
                <th>Address</th>
                <th>Roles</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Email</td>
                    <td>@item.FullName</td>
                    <td>@item.Address</td>
                    <td>
                        <!-- Simplify: Just show actions or roles if needed -->
                        <span class="badge bg-secondary">User</span>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
