@model IEnumerable<ASM.Models.Combo>

@{
    ViewData["Title"] = "Manage Combos";
}

<div class="container mt-5">
    <h2>Manage Combos</h2>
    <p>
        <a asp-action="CreateCombo" class="btn btn-primary">Create New Combo</a>
    </p>
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Price</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Price.ToString("N0")</td>
                    <td>@item.Description</td>
                    <td>
                        <a asp-action="EditCombo" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="DeleteCombo" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
