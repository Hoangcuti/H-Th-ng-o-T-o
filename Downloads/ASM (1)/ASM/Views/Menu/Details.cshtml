@model ASM.Models.FoodItem

@{
    ViewData["Title"] = Model.Name;
}

<div class="container mt-5">
    <div class="card shadow">
        <div class="row g-0">
            <div class="col-md-6">
               <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/placeholder.png" : Model.ImageUrl)" class="img-fluid rounded-start" alt="@Model.Name" style="width: 100%; height: 100%; object-fit: cover;">
            </div>
            <div class="col-md-6">
                <div class="card-body">
                    <h2 class="card-title">@Model.Name</h2>
                    <h4 class="text-primary mt-3">@Model.Price.ToString("N0") VNĐ</h4>
                    <p class="badge bg-secondary">@Model.Category</p>
                    <hr />
                    <h5>Description</h5>
                    <p class="card-text">@Model.Description</p>
                    
                    <div class="mt-4">
                        <form class="d-flex align-items-center">
                            <input type="number" class="form-control me-2" value="1" min="1" style="width: 80px;">
                            <button type="button" class="btn btn-success btn-lg">Add to Cart</button>
                        </form>
                    </div>
                    
                    <div class="mt-3">
                        <a asp-action="Index" class="btn btn-outline-secondary">Back to Menu</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
