@model List<ASM.Models.OrderDetail>

@{
    ViewData["Title"] = "Shopping Cart";
    decimal total = Model.Sum(x => x.Quantity * x.Price);
}

<div class="container mt-5">
    <h2>Shopping Cart</h2>
    @if (Model.Count == 0)
    {
        <p>Your cart is empty. <a asp-controller="Menu" asp-action="Index">Go shopping</a></p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Item</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Total</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FoodItem.Name</td>
                        <td>@item.Price.ToString("N0") VNĐ</td>
                        <td>@item.Quantity</td>
                        <td>@((item.Price * item.Quantity).ToString("N0")) VNĐ</td>
                        <td>
                            <a asp-action="RemoveFromCart" asp-route-id="@item.FoodItemId" class="btn btn-sm btn-danger">Remove</a>
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="3" class="text-end fw-bold">Grand Total:</td>
                    <td class="fw-bold">@total.ToString("N0") VNĐ</td>
                    <td></td>
                </tr>
            </tfoot>
        </table>

        <div class="text-end">
            <a asp-action="Checkout" class="btn btn-success">Proceed to Checkout</a>
        </div>
    }
</div>
