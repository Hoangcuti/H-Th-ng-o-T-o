@model ASM.Models.Order

@{
    ViewData["Title"] = "Order Details";
}

<div class="container mt-5">
    <h2>Order Details #@Model.Id</h2>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Order Date</dt>
        <dd class="col-sm-9">@Model.OrderDate</dd>
        
        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@Model.Status</dd>
        
        <dt class="col-sm-3">Total Amount</dt>
        <dd class="col-sm-9 fw-bold">@Model.TotalAmount.ToString("N0") VNĐ</dd>
    </dl>
    
    <h4>Items</h4>
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Item</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Subtotal</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var detail in Model.OrderDetails)
            {
                <tr>
                    <td>@detail.FoodItem?.Name</td>
                    <td>@detail.Price.ToString("N0") VNĐ</td>
                    <td>@detail.Quantity</td>
                    <td>@((detail.Price * detail.Quantity).ToString("N0")) VNĐ</td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-action="History" class="btn btn-secondary">Back to List</a>
</div>
